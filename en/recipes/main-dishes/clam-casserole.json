  "recipeIngredient": [
    "3 cans clams (6 1/2 oz), drained",
    "4 eggs, beaten",
    "1/4 cup butter, melted",
    "1/3 cup milk",
    "1 teaspoon salt",
    "1/2 cup onion, minced",
    "1/4 cup green pepper, minced",
    "18 saltine crackers, crushed"
  ],
  "recipeInstructions": "1. In a bowl, mix all ingredients.\n2. Pour the mixture into a well-greased Crock-Pot.\n3. Cover and cook on Low setting for 4 to 5 hours.",
