  "recipeIngredient": [
    "1 cup Mayonnaise",
    "2 tbsp Lemon Juice",
    "2 tbsp Whipping Cream",
    "1 1/2 tsp Salt",
    "1 tablespoon Wright's Hickory Seasoning",
    "1/4 teaspoon Curry Powder",
    "1 teaspoon Black Pepper",
    "4 cups Smoked Turkey, cubed",
    "1 cup Seedless Grapes",
    "2/3 cup Sliced Water Chestnuts",
    "2/3 cup Coarsely Chopped Walnuts",
    "1/2 cup Thinly Sliced Celery"
  ],
  "recipeInstructions": "1. Combine the dressing ingredients in a bowl and set aside.\n2. In another bowl, combine the remaining salad ingredients.\n3. Pour the dressing over the turkey mixture and toss lightly.",
