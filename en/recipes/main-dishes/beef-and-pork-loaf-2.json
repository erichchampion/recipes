  "name": "Beef and Pork Loaf",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Main Dishes",
  "keywords": [
    "main dish",
    "slow cooker"
  ],
  "recipeIngredient": [
    "1 1/4 pounds Ground Beef",
    "1/2 pound Ground Lean Pork",
    "2 cups Soft Bread Crumbs (2 slices)",
    "1/4 cup Onion, minced",
    "1 cup Milk",
    "1 Egg, beaten",
    "2 teaspoons Salt",
    "1/4 teaspoon Pepper",
    "1 dash Nutmeg, Cloves or Cinnamon",
    "1/2 teaspoon Chili Powder, optional"
  ],
  "recipeInstructions": "1. Mix all ingredients together.\n2. Form the mixture into a loaf and place it in the crockpot with the rounded top facing up.\n3. Cook on low for 8-9 hours.",
