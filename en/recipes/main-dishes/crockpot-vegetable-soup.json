  "recipeIngredient": [
    "1 chopped onion",
    "2 medium chopped potatoes",
    "3 cans chicken broth",
    "14 oz can whole tomatoes (drain)",
    "1 large can V-8 juice",
    "2 stalks celery, chopped",
    "1 cup chopped spinach",
    "1/2 teaspoon salt and pepper",
    "1 teaspoon dried basil",
    "1/2 teaspoon dried thyme",
    "1 tablespoon butter",
    "2 sliced carrots",
    "4 cups water",
    "Dash red pepper flakes"
  ],
  "recipeInstructions": "1. Add bow tie pasta if desired.\n2. Combine all ingredients in the crockpot.\n3. Cook on low for 8-10 hours or high for 4-6 hours.",
