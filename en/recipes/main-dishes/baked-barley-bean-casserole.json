  "recipeIngredient": [
    "2 cups Cooked & mashed Amaranth Beans",
    "1 cup Pre-cooked Amaranth Bits-O-Barley",
    "1 cup Soy Milk",
    "1/2 cup Raw Amaranth Wheat Germ",
    "2 tbsp Unrefined Vegetable Oil",
    "1/4 cup Onion, minced and sauteed",
    "3 tablespoons Prepared Mustard",
    "1/2 cup Honey",
    "1/2 cup Catsup of choice",
    "1/2 teaspoon Garlic Powder",
    "1/2 teaspoon Onion Powder",
    "1/2 teaspoon Chili Powder",
    "Sea Salt to taste (optional)"
  ],
  "recipeInstructions": "1. Preheat oven to 350°F.\n2. Mix all ingredients together in a large bowl.\n3. Let stand for 30 minutes.\n4. Pour into an oiled casserole dish and bake for 40 minutes.",
