    "2 tablespoons horseradish",
    "2 tablespoons ketchup",
    "1 egg",
    "1 cup dry bread crumbs",
    "1/2 cup evaporated skim milk",
    "1 teaspoon salt",
    "pepper to taste",
    "1 large onion, finely minced",
    "4 slices bacon, cooked and crumbled"
