  "recipeIngredient": [
    "3 ounces Cornmeal",
    "3 ounces All-purpose flour",
    "2 Eggs",
    "8 ounces Buttermilk",
    "1 tablespoon Onion, diced finely",
    "3 ounces Fresh corn kernels",
    "1 teaspoon Salt"
  ],
  "recipeInstructions": "1. Combine all ingredients in a mixing bowl and whisk until smooth.\n2. Pour batter onto a hot griddle to cook.",
