  "recipeIngredient": [
    "5 cups Water",
    "4 large Onions; sliced into rings",
    "2 small Zucchini; sliced",
    "1 medium Eggplant; peeled and chopped",
    "or 2 small Japanese eggplants",
    "2 Garlic cloves; crushed",
    "6 oz Tomato paste",
    "1/2 cup Red wine; optional",
    "1/4 cup Fresh basil; chopped",
    "2 tbsp Soy sauce",
    "Freshly ground pepper to taste"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large soup pot.\n2. Bring mixture to a boil, then cover and reduce heat.\n3. Simmer over medium-low heat for about 1 hour, or until vegetables are tender.",
