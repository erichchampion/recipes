  "recipeIngredient": [
    "2 quarts Water",
    "5 Vegetable Bouillon Cubes",
    "1 tablespoon Salt",
    "1 teaspoon Pepper",
    "2 stalks Celery, chopped",
    "1 large Onion, chopped",
    "2 cans Diced Tomatoes (8 oz each)",
    "1 package Frozen Cut Okra",
    "2 packages Frozen Mixed Vegetables (#2 cans)",
    "--(beans, peas, carrots,",
    "--corn, and limas)",
    "1 can Pinto Beans (15 oz)",
    "1 medium Potato, diced",
    "1/2 Green Pepper, diced",
    "1 pound Mushrooms, sliced",
    "2 cups Tomato Juice",
    "1 teaspoon Cayenne Pepper"
  ],
  "recipeInstructions": "1. In a large covered pot, combine water, bouillon cubes, salt, and a dash of pepper.\n2. Add the remaining ingredients.\n3. Cook together for 5-6 hours.\n4. Excellent reheated. Keep in freezer containers all year round, with each container holding enough soup for one family sitting.",
