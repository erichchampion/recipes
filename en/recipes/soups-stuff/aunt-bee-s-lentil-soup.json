  "recipeIngredient": [
    "1 lb Smoked sausage (large link), sliced",
    "1 lb Lentils",
    "1/2 cup Chopped onion",
    "1/2 cup Sliced celery",
    "1/2 cup Sliced carrots",
    "1/8 tsp Garlic salt",
    "2 1/2 tbsp Salt",
    "1 1/2 tbsp Oregano",
    "6 oz Can tomato paste",
    "8 cups Water",
    "20 oz Can tomatoes"
  ],
  "recipeInstructions": "1. In a large stock pot, combine all ingredients except the tomatoes.\n2. Cook for 1 hour and 30 minutes.\n3. Add the tomatoes and simmer for an additional 30 minutes.\n4. Serves 12.",
