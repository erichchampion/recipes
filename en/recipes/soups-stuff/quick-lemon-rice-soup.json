  "recipeIngredient": [
    "1 small onion or 3 scallions",
    "chopped",
    "3 cups fresh kale, chopped",
    "1/2 teaspoon garlic powder",
    "1/8 teaspoon black pepper",
    "1/8 teaspoon turmeric",
    "1/3 cup vegetable broth",
    "3 cups pre-cooked rice",
    "8 cups water or vegetable broth",
    "1/4 cup lemon juice",
    "1 cup nutritional yeast",
    "1 tablespoon tamari or soy sauce"
  ],
  "recipeInstructions": "1. In a large pot, sauté onion, kale, and seasonings in 1/3 cup vegetable broth over medium heat for 5 minutes.\n2. Add remaining ingredients and simmer for an additional 10 minutes.\n3. Serve warm.",
