  "recipeIngredient": [
    "1 pound Chopped beef",
    "1/2 cup Chopped onion",
    "16 oz. Red beans",
    "16 oz. Refried beans",
    "8 oz. Tomato sauce",
    "1 cup Water",
    "1 teaspoon Chopped hot red peppers",
    "1/2 teaspoon Salt",
    "1/2 teaspoon Garlic salt",
    "1/8 teaspoon Pepper",
    "1/8 teaspoon Cayenne pepper",
    "3 tablespoons Chili powder",
    "1 tablespoon Molasses"
  ],
  "recipeInstructions": "1. Brown the beef and onions in a Dutch oven until the beef is no longer pink.\n2. Pour off any excess fat from the pan.\n3. Add the remaining ingredients to the pot, stirring occasionally.\n4. Cover and simmer for 1 hour.",
