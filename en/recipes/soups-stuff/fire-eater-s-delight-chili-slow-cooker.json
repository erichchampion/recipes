{
  "@type": "Recipe",
  "identifier": "fire-eater-s-delight-chili-slow-cooker",
  "name": "Fire Eater's Delight Chili (Slow Cooker)",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Soups & Stuff",
  "keywords": [
    "chili",
    "soups"
  ],
  "recipeIngredient": [
    "3 pounds ground beef",
    "3 tablespoons chili powder",
    "2 teaspoons cumin",
    "2 cubes beef bouillon",
    "1 teaspoon paprika",
    "1 teaspoon oregano",
    "12 oz can beer",
    "1/3 cup water",
    "15 oz can kidney beans, undrained",
    "4 cloves garlic",
    "1 medium onion, chopped",
    "6 oz can tomato sauce",
    "1/2 teaspoon coriander",
    "hot paprika",
    "1 tablespoon sugar",
    "1/2 teaspoon salt",
    "1/2 teaspoon pepper"
  ],
  "recipeInstructions": "1. Brown ground beef in a skillet and drain.\n2. Add the browned beef to the slow cooker.\n3. Stir in the remaining ingredients.\n4. Cook on HIGH for 3-4 hours or on LOW for 6-8 hours.\n5. Serve, allowing it to cool slightly before serving.",
  "url": null
}
