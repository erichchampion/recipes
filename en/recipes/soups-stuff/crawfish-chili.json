  "recipeIngredient": [
    "2 lb Lean ground beef",
    "3 tbsp Chili powder",
    "2 lb Crawfish tails",
    "1 can (8 oz) tomato sauce",
    "1 tsp Garlic, chopped fine",
    "1 cup Dry white wine",
    "1 cup Water",
    "1 teaspoon Lemon or lime juice",
    "1 cup Chopped onions",
    "1 tsp Cayenne pepper",
    "1 can Bacon drippings",
    "1 tbsp Dried parsley"
  ],
  "recipeInstructions": "1. Brown the meat in bacon drippings.\n2. Combine all other ingredients with the meat and bring to a boil.\n3. Simmer for a few hours.",
