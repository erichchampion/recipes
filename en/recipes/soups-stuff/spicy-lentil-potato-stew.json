  "recipeIngredient": [
    "1/2 cup Lentils (uncooked)",
    "1 cup Chopped carrots",
    "1/4 cup Chopped celery leaves",
    "3 Cloves chopped garlic",
    "1/2 tsp Dried basil",
    "2 cups Tomato juice",
    "2 medium Potatoes (don't peel)",
    "-(chop into 1/2 inch cubes)",
    "1/2 cup Chopped celery",
    "1 tbsp Chili powder (or less)",
    "1/2 tsp Dried oregano",
    "3/4 cup Water"
  ],
  "recipeInstructions": "1. Add all ingredients to a large saucepan.\n2. Mix well.\n3. Bring to a boil, then reduce heat and cover.\n4. Simmer until the vegetables are tender, which should take about 45 minutes.",
