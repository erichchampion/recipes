  "recipeIngredient": [
    "3 lb Lean ground beef",
    "3 tbsp Brown sugar",
    "1 tsp Thyme",
    "1 tsp Salt",
    "1 tsp Cumin seed",
    "1 tsp Garlic powder",
    "2 Bay leaves",
    "1 tsp Cilantro",
    "1/4 tsp Oregano (Mexican preferred)",
    "1 tsp Cayenne pepper",
    "2 tbsp Paprika",
    "46 oz V-8 juice",
    "1 cup Chopped onions",
    "16 oz Peeled tomatoes",
    "4 cups Pinto or kidney beans"
  ],
  "recipeInstructions": "1. Brown the beef and drain any excess fat.\n2. Add all remaining ingredients to a large pot.\n3. Cover the pot and cook on medium heat for approximately 4 hours, stirring occasionally.",
