  "recipeIngredient": [
    "32 ounces Tomato juice",
    "14.5 ounces Tomatoes, pureed",
    "2 cups Water",
    "2 large Potatoes, chopped",
    "15 ounces Garbanzo beans, canned, drained",
    "15 ounces Kidney beans, canned, drained",
    "1 cup Lentils, rinsed and drained",
    "1 large Onion, chopped",
    "2 teaspoons Garlic powder",
    "1 cup Red pepper, diced",
    "1 cup Green pepper, diced",
    "10 ounces Frozen broccoli, chopped",
    "2 large Carrots, grated",
    "2 tablespoons Dried parsley",
    "2 tablespoons Chili powder",
    "1 teaspoon Dried basil",
    "1 teaspoon Ground cumin"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large pot.\n2. Bring to a boil.\n3. Reduce heat and simmer, covered, for 30-45 minutes or until lentils are tender.",
