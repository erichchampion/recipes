    "2 large Garlic cloves, pressed",
    "1 1/4 tsp Paprika",
    "1/2 tsp Caraway seeds",
    "1 Bouillon cube (vegetable)",
    "2 tbsp Water",
    "1 cup Peas, fresh or frozen",
    "1/2 tsp Black pepper",
    "2 cups Tomatoes, fresh and chopped",
    "3 1/2 tsp Marjoram",
    "1/4 cup Safflower oil or vegetable stock",
    "3 cups Noodles, eggless, cooked"
