  "recipeIngredient": [
    "2 cups Raw cashew nuts",
    "1 box AM Quick Brown Rice",
    "--(Vegetable and Herb), cooked",
    "1 cup Cooked AM 7 Grain Cereal",
    "2 cups Soy milk",
    "1 large onion, chopped",
    "3/4 cup AM Wheatgerm",
    "4 tablespoons AM Canola Oil",
    "2 tablespoons Soy sauce",
    "1 teaspoon Sea salt (optional)",
    "4 tablespoons Minced parsley",
    "1/2 teaspoon Thyme",
    "1/2 teaspoon Ground celery seed",
    "1/2 teaspoon Ground sage",
    "1 teaspoon Onion powder",
    "1 teaspoon Garlic powder"
  ],
  "recipeInstructions": "1. Chop the nuts finely, or run through a food grinder.\n2. Add the remaining ingredients and mix well.\n3. Place in a baking dish and bake at 350°F uncovered for 1 hour or until done.\n4. Serve with favorite gravy.",
