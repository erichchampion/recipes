  "recipeIngredient": [
    "1 clove garlic",
    "1 tablespoon ginger root",
    "1/2 medium Spanish onion",
    "1 splash Rose's lime juice",
    "1 tangerine, peeled and diced",
    "1/2 pear, cored and diced",
    "4 strips dry mango, diced",
    "3 sprigs watercress, finely chopped",
    "2 tablespoons dried mint",
    "1 tablespoon olive oil",
    "Salt and pepper"
  ],
  "recipeInstructions": "1. In a medium bowl, mix together the garlic, ginger, and onion with the lime juice.\n2. Stir in the remaining ingredients and season to taste.\n3. Serve with chips, seafood, and vegetables.",
