  "recipeIngredient": [
    "10 cups coarsely ground zucchini",
    "4 cups finely chopped onion",
    "5 tablespoons salt",
    "4 cups sugar",
    "2 1/4 cups vinegar",
    "1 teaspoon dry mustard",
    "1 teaspoon turmeric",
    "2 teaspoons celery seed",
    "1 teaspoon black pepper",
    "1 green pepper, finely chopped",
    "1 red pepper or pimento, chopped"
  ],
  "recipeInstructions": "1. After rinsing and squeezing the zucchini and onion dry, add the remaining ingredients.\n2. Bring all the ingredients to a boil.\n3. Cook for 30 minutes.\n4. Spoon into sterilized jars and seal.",
