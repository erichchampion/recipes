  "recipeIngredient": [
    "1/4 cup Salt",
    "2 cups Red pepper flakes",
    "1 tbsp Finely ground black pepper",
    "1 tbsp White pepper",
    "2 tbsp Paprika",
    "1 1/2 tbsp Onion powder",
    "1 tbsp Garlic powder",
    "1 tsp Sweet basil",
    "1/2 tsp Dry hot mustard",
    "1/2 tsp Ground bay leaves",
    "1/4 tsp File powder",
    "1/4 tsp Thyme",
    "1/4 tsp Tarragon",
    "1/8 tsp Oregano",
    "1/8 tsp Rosemary"
  ],
  "recipeInstructions": "1. Mix all ingredients together well.\n2. Store in a tightly covered glass jar for use as needed.\n3. Use this seasoning mix to season seafood dishes. Do not add extra salt to the dish.",
