  "recipeIngredient": [
    "1/2 lb Tofu, firm, crumbled",
    "1/3 cup Lemon juice, freshly squeezed",
    "1/3 cup Nutritional yeast flakes",
    "1/3 cup Tahini, raw",
    "3 tbsp Tamari",
    "3 tbsp Water",
    "1 tsp Basil, dried",
    "1/8 tsp Turmeric",
    "1 Garlic clove, peeled",
    "1/4 tsp Pepper"
  ],
  "recipeInstructions": "1. Add all of the ingredients to a blender.\n2. Blend until smooth.\n3. Serve this sauce warm or at room temperature.",
