  "recipeIngredient": [
    "2 tablespoons Balsamic vinegar",
    "2 tablespoons Orange juice",
    "1 tablespoon Dijon mustard",
    "1 tablespoon Honey",
    "1/2 teaspoon Grated orange peel",
    "1/2 teaspoon Red pepper flakes",
    "2 cups Strawberries, sliced",
    "3 tablespoons Raisins",
    "3 tablespoons Walnuts, chopped"
  ],
  "recipeInstructions": "1. Combine the first six ingredients and whisk to blend thoroughly.\n2. Add the remaining ingredients and toss.\n3. Serve this chutney-style accompaniment with grilled fish or chicken.",
