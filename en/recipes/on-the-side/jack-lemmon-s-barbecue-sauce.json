  "recipeIngredient": [
    "3/4 quart Catsup",
    "1 tsp English mustard",
    "1 tsp Freshly ground black pepper",
    "1 tbsp Worcesteshire sauce",
    "1 Clove garlic",
    "1/2 medium Onion",
    "4 tbsp Lemon juice",
    "1 Bay leaf",
    "4 tbsp Sharp salad dressing",
    "3/4 cup Maple syrup",
    "1 cup Butter",
    "Chili powder"
  ],
  "recipeInstructions": "1. Mix all ingredients together.\n2. Bring the mixture to a boil.\n3. Simmer for one hour, stirring occasionally.\n4. Remove onion and bay leaf before serving.",
