{
  "@type": "Recipe",
  "identifier": "tart-n-tangy-italian-dressing",
  "name": "Tart 'n' Tangy Italian Dressing",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "dressings",
    "garlic",
    "side dishes"
  ],
  "recipeIngredient": [
    "1 cup Olive oil",
    "1/2 cup Wine vinegar",
    "1 tsp Minced onion",
    "1 tsp Seasoned salt",
    "3/4 tsp Garlic powder",
    "1/2 tsp Chives",
    "1/2 tsp Parsley flakes",
    "1/2 tsp Sugar",
    "1/4 tsp Dry mustard",
    "1/4 tsp Oregano",
    "1/8 tsp White pepper",
    "Cayenne or red pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a jar.\n2. Cover and shake vigorously.\n3. Chill for 1 hour to allow flavors to blend.\n4. Shake well before serving.\n5. Makes 1 1/2 cups.",
  "url": null
}
