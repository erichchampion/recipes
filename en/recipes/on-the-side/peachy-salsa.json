  "recipeIngredient": [
    "1/3 cup Cilantro, lightly packed",
    "2 cups Peaches, peeled and diced",
    "2 cups Tomatoes, diced",
    "1 teaspoon Lemon juice",
    "1 pinch Black pepper",
    "1/4 teaspoon Salt",
    "1/2 teaspoon Crushed Garlic",
    "1 teaspoon Olive oil",
    "2 teaspoons Balsamic vinegar",
    "Cayenne, to taste"
  ],
  "recipeInstructions": "1. Combine all ingredients in a blender or food processor.\n2. Blend for a few seconds until smooth and combined.\n3. Serve immediately over hot, fresh pasta.\n4. Alternatively, refrigerate the salsa until ready to serve.",
