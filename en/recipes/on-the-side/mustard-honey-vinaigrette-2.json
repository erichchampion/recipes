  "recipeIngredient": [
    "1/4 cup Balsamic vinegar",
    "2 tablespoons Honey",
    "2 tablespoons Dijon mustard",
    "1 1/2 teaspoons Salt",
    "1/2 teaspoon Pepper",
    "1/2 teaspoon Tabasco sauce",
    "2 cloves Garlic, minced",
    "3/4 cup Vegetable oil"
  ],
  "recipeInstructions": "1. Whisk together vinegar, honey, mustard, salt, pepper, Tabasco and garlic.\n2. Gradually whisk in the vegetable oil until combined. (Can be made 1 day ahead of use.)",
