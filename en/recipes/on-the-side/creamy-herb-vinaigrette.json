  "name": "Creamy Herb Vinaigrette",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "dressings",
    "side dishes"
  ],
  "recipeIngredient": [
    "1 tablespoon Mayonnaise",
    "1 tablespoon Dijon mustard",
    "1/2 teaspoon Salt",
    "1/4 teaspoon Pepper",
    "3/4 cup Spanish olive oil",
    "3 tablespoons Flavored vinegar",
    "1 tablespoon Parsley, minced",
    "1/2 teaspoon Thyme, minced",
    "1/2 teaspoon Oregano, minced"
  ],
  "recipeInstructions": "1. Place the mayonnaise, mustard, salt, pepper, oil, and vinegar in a food processor.\n2. Pulse until smooth.\n3. Add the minced herbs and stir to mix.\n4. Refrigerate.",
