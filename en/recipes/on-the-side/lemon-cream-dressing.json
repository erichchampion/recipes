  "recipeIngredient": [
    "1/2 cup Tahini",
    "8 oz Firm (or firm silken) tofu",
    "1 Lemon, zested and juiced",
    "1/4 cup Cider vinegar",
    "1 Garlic clove, minced",
    "1/4 cup Brown rice syrup",
    "OR -",
    "1/3 cup Honey",
    "2 tbsp White miso",
    "1/2 cup Water"
  ],
  "recipeInstructions": "1. Add all ingredients to a blender.\n2. Blend until the mixture is smooth and well combined.\n3. Allow the dressing to cool before using as desired.",
