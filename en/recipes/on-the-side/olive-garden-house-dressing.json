  ],
  "recipeIngredient": [
    "8 oz Paul Newman's Vinegar",
    "2 cups Oil",
    "10 ml Garlic, peeled and halved",
    "1/2 tsp Dried basil",
    "1/2 tsp Dried oregano",
    "3 packets Sweet 'n' Low (or 1 tbsp Sugar)"
  ],
  "recipeInstructions": "1. Pour all ingredients into a bottle of dressing.\n2. Shake well to combine.\n3. Refrigerate for at least 24 hours before using.",
