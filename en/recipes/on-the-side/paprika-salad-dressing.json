  "recipeIngredient": [
    "1 cup Mayonnaise",
    "3 Garlic cloves",
    "2 tablespoons Chili sauce",
    "2 tablespoons Catsup",
    "1 teaspoon Paprika",
    "1 teaspoon Pepper",
    "1 teaspoon Mustard (dry or prepared)",
    "1 teaspoon Onion juice",
    "1 teaspoon Worcestershire sauce",
    "1 teaspoon Water",
    "1/4 teaspoon Salt",
    "Juice of 1 Lemon",
    "Hot sauce to taste",
    "1/2 cup Salad oil"
  ],
  "recipeInstructions": "1. Combine all ingredients except salad oil in a container of electric blender.\n2. Blend for 5 seconds.\n3. Add salad oil slowly, continuing to blend.\n4. Blend for an additional 5 seconds after adding the oil.",
