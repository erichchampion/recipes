  "recipeIngredient": [
    "3/4 cup Salad oil",
    "1/4 cup Tarragon vinegar",
    "2 tablespoons Tomato catsup",
    "1/2 teaspoon Hot pepper sauce",
    "2 tablespoons Horseradish",
    "1 tablespoon Creole mustard",
    "1 teaspoon Worcestershire sauce",
    "1/2 cup Celery, chopped",
    "1/2 cup Onions, chopped",
    "1 Garlic clove",
    "2 teaspoons Paprika",
    "1 teaspoon Salt"
  ],
  "recipeInstructions": "1. Place all ingredients in blender in the order listed.\n2. Blend for 5 seconds; pause; blend for an additional 5 seconds longer.\n3. Refrigerate overnight or for a longer period of time.\n4. Serve over cooked shrimp or salads.",
