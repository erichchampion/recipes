  "name": "North Carolina: Eastern Rub and Sauce",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "sauces",
    "side dishes"
  ],
  "recipeIngredient": [
    "RUB:",
    "2 teaspoons salt",
    "2 teaspoons brown sugar",
    "2 teaspoons cumin",
    "2 teaspoons chile powder",
    "2 teaspoons black pepper",
    "1 teaspoon cayenne pepper",
    "1/4 cup paprika",
    "SAUCE:",
    "1 cup white vinegar",
    "1 cup cider vinegar",
    "1 tablespoon sugar",
    "1 tablespoon red pepper flakes",
    "1 tablespoon tabasco",
    "1 tablespoon black pepper"
  ],
  "recipeInstructions": "1. Use rub on meat and allow to set until rub looks moist.\n2. For sauce, blend all ingredients and allow flavors to blend.",
