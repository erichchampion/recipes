  "recipeIngredient": [
    "2 tablespoons whole grain mustard",
    "2 teaspoons rice wine vinegar",
    "1/4 teaspoon sugar",
    "1/4 teaspoon salt",
    "1/4 teaspoon black pepper",
    "2 tablespoons vegetable oil",
    "1 tablespoon sesame oil",
    "2 tablespoons chopped green onions"
  ],
  "recipeInstructions": "1. In a small bowl, whisk together the mustard, vinegar, sugar, salt, and black pepper.\n2. Slowly whisk in the vegetable oil.\n3. Mix in the chopped green onions.",
