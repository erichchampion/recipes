  "recipeIngredient": [
    "1/3 cup Balsamic vinegar",
    "3 tablespoons Grated Parmesan cheese",
    "1 teaspoon Salt",
    "3 teaspoons Black pepper (freshly ground)",
    "1/4 cup Olive oil (extra light)",
    "2 tablespoons Oregano, chopped",
    "1 Garlic clove, minced finely",
    "2 tablespoons Fresh basil, minced",
    "2 teaspoons Soy sauce",
    "1/3 cup Chablis"
  ],
  "recipeInstructions": "1. Combine all ingredients in a bowl.\n2. Whisk or stir until well combined.\n3. Refrigerate for up to 2 days. Shake the dressing before using and pour generously over salad.",
