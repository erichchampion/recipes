  "recipeIngredient": [
    "1/2 cup Cranberry-juice Cocktail",
    "1 cup Orange juice",
    "1 cup Water",
    "1/3 cup Sugar",
    "2 Cinnamon sticks (broken)",
    "2 Orange slices (quartered)",
    "1/8 tsp Nutmeg",
    "2 tsp Instant tea"
  ],
  "recipeInstructions": "1. Combine all ingredients in a medium-size saucepan. Heat just to boiling; reduce heat; cover.\n2. Simmer for 5 minutes. Stir in the tea.\nServe hot.",
