  "recipeIngredient": [
    "2 tsp sunflower oil",
    "5 oz low fat natural yogurt",
    "1 tsp ground cumin",
    "½ tsp ground turmeric",
    "¼ tsp chili powder",
    "¼ tsp ground coriander",
    "¼ tsp garam masala",
    "¼ tsp paprika",
    "1 large clove garlic, crushed"
  ],
  "recipeInstructions": "1. Mix all the ingredients together and leave to marinade for at least one hour.\n2. Cook over a barbecue, under a grill or in the oven at 230°C, 450°F, gas mark 8.",
