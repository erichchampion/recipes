  "recipeIngredient": [
    "2 Tablespoons oil (bacon drippings)",
    "1 Medium onion, slivered",
    "4 Cloves garlic, chopped",
    "28 Fluid Ounces crushed tomatoes",
    "1 1/2 Cups ketchup",
    "1 Cup fresh orange juice",
    "6 Tablespoons fresh lemon juice",
    "6 Tablespoons red wine vinegar",
    "1/2 Cup water",
    "2 Tablespoons liquid smoke flavoring",
    "1/4 Cup honey",
    "1/2 Cup brown sugar, packed",
    "3 Tablespoons crystallized ginger, finely chopped",
    "2 Tablespoons dark molasses",
    "1 Tablespoon Worcestershire sauce",
    "1/4 Teaspoon tobasco",
    "2 Tablespoons chili powder",
    "1 Tablespoon coriander, ground",
    "1 Tablespoon dry mustard",
    "1 Teaspoon salt"
  ],
  "recipeInstructions": "1. Heat oil in a large pan over medium heat.\n2. Add onion and sauté until golden brown, about 5-7 minutes.\n3. Add garlic and cook for an additional minute.\n4. Stir in the remaining ingredients.\n5. Bring the mixture to a boil.\n6. Reduce heat to low and simmer for 45 minutes, stirring frequently.",
