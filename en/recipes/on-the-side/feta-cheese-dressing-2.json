  "recipeIngredient": [
    "1 cup feta cheese",
    "1 cup mayonnaise",
    "1/2 teaspoon garlic powder",
    "1/4 cup white wine vinegar",
    "1/2 teaspoon dried oregano",
    "2 tablespoons soy sauce",
    "2 teaspoons olive oil"
  ],
  "recipeInstructions": "1. Combine all ingredients in a food processor fitted with a metal blade.\n2. Blend for 5 seconds until smooth and well combined.\n3. Good with most salads.",
