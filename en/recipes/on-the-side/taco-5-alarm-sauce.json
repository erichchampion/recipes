  "name": "Taco 5 Alarm Sauce",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "miscellaneous",
    "sauces"
  ],
  "recipeIngredient": [
    "1 can tomato paste (6 ounces)",
    "1 teaspoon chili powder",
    "1 teaspoon soy sauce",
    "dash Tobasco sauce",
    "pinch pepper",
    "1 tsp onion",
    "salt",
    "1/4 cup undrained pickle relish",
    "1 tbsp instant POSTUM drink powder",
    "For coloring",
    "1 tsp dark molasses",
    "1 tsp dry mustard",
    "1/4 cup ketchup",
    "1/2 cup water",
    "1/2 tsp cumin powder",
    "10 oz tomato soup"
  ],
  "recipeInstructions": "1. In a saucepan, combine all ingredients.\n2. Stir over low heat to blend all flavors.\n3. Makes enough sauce to cover 18 to 20 tacos.\n4. Freeze unused portion in family sized containers.",
