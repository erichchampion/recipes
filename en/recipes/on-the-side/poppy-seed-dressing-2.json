  "recipeIngredient": [
    "1/3 white onion, grated",
    "1 1/2 cups sugar",
    "<or 1 cup sugar & 6 packets Sweet 'n Low)",
    "2 teaspoons dry mustard",
    "1 teaspoon Papa Dash lite salt, optional",
    "2/3 cup white vinegar",
    "2 cups liquid Butter Buds",
    "2 tablespoons poppy seeds"
