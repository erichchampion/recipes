  "recipeIngredient": [
    "1 cup Ketchup",
    "1/4 cup Packed brown sugar",
    "1/4 cup White vinegar",
    "1/4 cup Water",
    "1 1/2 teaspoons Celery seed",
    "1/4 teaspoon Salt",
    "Dash garlic powder",
    "Dash pepper",
    "1 1/2 teaspoons Worcestershire sauce",
    "1 1/2 teaspoons Prepared horseradish",
    "1 medium Onion, chopped"
  ],
  "recipeInstructions": "1. Combine all ingredients in a 2-quart glass casserole.\n2. Cover with waxed paper.\n3. Cook in microwave oven for 3 minutes at High, or until hot; stir once.\nYield: about 1-1/2 cups.",
