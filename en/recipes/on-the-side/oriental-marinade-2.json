  "recipeIngredient": [
    "1/4 cup soy sauce",
    "2 tablespoons lemon juice",
    "1 tablespoon brown sugar",
    "2 cloves garlic, finely chopped",
    "1 tablespoon freshly grated ginger root",
    "2 tablespoons chopped green onions",
    "2 tablespoons sesame oil",
    "1/2 teaspoon hot sauce",
    "pinch black pepper"
