  "recipeIngredient": [
    "1 cup canned tomatoes",
    "1/4 teaspoon onion powder",
    "2 tablespoons lemon juice",
    "1 teaspoon sweetener",
    "1/4 cup cooked rice or pasta",
    "1/8 teaspoon celery salt",
    "1/8 teaspoon salt",
    "1/8 teaspoon garlic powder",
    "1/8 teaspoon basil"
