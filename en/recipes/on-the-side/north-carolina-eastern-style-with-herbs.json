  "recipeIngredient": [
    "1 cup cider vinegar",
    "1/2 cup water",
    "2/3 cup minced onion",
    "1 clove garlic",
    "1 teaspoon pepper",
    "1/2 teaspoon salt",
    "2 teaspoons red pepper flakes",
    "1 tablespoon sugar",
    "1 bay leaf",
    "2 teaspoons thyme",
    "3 tablespoons peanut oil",
    "3 teaspoons dry mustard",
    "1 tablespoon cold water"
  ],
  "recipeInstructions": "1. Combine all ingredients except the last two in a saucepan.\n2. Bring to a boil and cook for five minutes.\n3. Dissolve mustard in cold water, then add it to the mixture.",
