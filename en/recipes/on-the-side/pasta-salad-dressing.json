    "1/3 cup Vegetable oil",
    "1/3 cup Olive oil",
    "2 tbsp Parsley, fresh, chopped",
    "2 Cloves garlic, minced",
    "2 tsp Dried whole basil",
    "1 tsp Dried whole dillweed",
    "1 tsp Salt",
    "1/2 tsp Pepper",
    "1/2 tsp Sugar",
    "1/2 tsp Dried whole oregano",
