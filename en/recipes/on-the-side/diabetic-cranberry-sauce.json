  "recipeIngredient": [
    "3 cups cranberries",
    "1.5 cups boiling water",
    "0.5 cup orange juice",
    "1 teaspoon Sucaryl Solution",
    "For spiced cranberry sauce,",
    "2 tablespoons lemon juice",
    "0.125 teaspoons nutmeg",
    "0.125 teaspoons cloves",
    "0.125 teaspoons cinnamon"
  ],
  "recipeInstructions": "1. Cook cranberries in boiling water until skins are broken.\n2. Add the remaining ingredients.\n3. Chill in refrigerator.\nOne serving may be exchanged for: 1/2 fruit exchange.",
