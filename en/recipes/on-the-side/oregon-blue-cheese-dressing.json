  "recipeIngredient": [
    "1 cup Mayonnaise",
    "8 oz Carton commercial sour cream",
    "1 1/2 pk (4-oz ea) blue cheese - crumbled",
    "1/4 cup Olive oil",
    "1 tbsp Milk",
    "1 tsp Cider vinegar",
    "1 cl Garlic - minced",
    "1/8 tsp Dry mustard",
    "1/8 tsp Freshly ground pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a small bowl.\n2. Stir until well blended.\n3. Cover and chill.\n4. Serve over fruit or salad greens.",
