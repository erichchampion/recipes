  "recipeIngredient": [
    "1/2 cup Sesame or soy oil",
    "1/4 cup Soy sauce",
    "1/3 cup Diced onion",
    "1/4 cup Diced celery",
    "3 tbsp Rice wine vinegar",
    "2 tbsp Diced fresh ginger",
    "2 tsp Sugar",
    "1 1/2 tsp Grated lemon peel",
    "1/2 tsp Catsup",
    "1/4 tsp Black pepper"
  ],
  "recipeInstructions": "1. Place all ingredients into a blender or food processor.\n2. Blend until the vegetables are pureed.\n3. Store in a covered jar.\n4. Shake thoroughly before using.",
