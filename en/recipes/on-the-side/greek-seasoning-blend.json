    "spices"
  ],
  "recipeIngredient": [
    "2 teaspoons salt",
    "2 teaspoons dried oregano",
    "1 1/2 teaspoons onion powder",
    "1 1/2 teaspoons garlic powder",
    "1 teaspoon cornstarch",
    "1 teaspoon pepper",
    "1 teaspoon beef-flavored bouillon granules",
    "1 teaspoon dried parsley flakes",
    "1/2 teaspoon ground cinnamon",
    "1/2 teaspoon ground nutmeg"
  ],
  "recipeInstructions": "1. In a bowl, mix all the ingredients together.\n2. Transfer the mixture to an airtight container.\n3. Store in a cool, dark place for up to six months.\n4. Use with steaks, pork chops, chicken, or fish.",
