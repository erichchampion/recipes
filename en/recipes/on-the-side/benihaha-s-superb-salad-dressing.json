  "recipeIngredient": [
    "1/2 cup Soybean oil",
    "1/4 cup White vinegar",
    "3 tbsp Tomato paste",
    "1 tbsp Soy sauce",
    "1/2 tsp Salt",
    "1/2 tsp Ground ginger",
    "1/2 cup Celery, sliced thin",
    "1/4 cup Onions, coarsely chopped"
