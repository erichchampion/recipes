  "recipeIngredient": [
    "8 cups cranberries",
    "1 lb onions",
    "2 cups water",
    "1 tsp pepper",
    "1 tbsp cloves",
    "1 tbsp allspice",
    "1 tbsp celery seed",
    "1 tbsp cinnamon",
    "2 cups red wine vinegar",
    "4 cups brown sugar",
    "1 tbsp salt",
    "1 large bottle tomato ketchup"
