  "recipeIngredient": [
    "1 medium cucumber - seeded and chopped",
    "1 1/2 cups buttermilk",
    "1 clove garlic - crushed",
    "1/2 teaspoon salt",
    "1/4 cup red wine vinegar",
    "2 teaspoons prepared horseradish",
    "1 teaspoon dill weed",
    "1 teaspoon mild paprika"
