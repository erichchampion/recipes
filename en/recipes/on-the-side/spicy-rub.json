  "recipeIngredient": [
    "1 tbsp black pepper",
    "1 tbsp white pepper",
    "1 tbsp sugar",
    "2 tsp cayenne pepper",
    "2 tbsp chili powder",
    "1 tbsp cumin",
    "1 tbsp garlic powder",
    "1 tbsp brown sugar",
    "1 tbsp crushed dried oregano",
    "4 tbsp paprika",
    "1 tsp dry mustard",
    "1 tbsp celery salt",
    "1 tbsp salt"
  ],
  "recipeInstructions": "1. Thoroughly mix all ingredients.\n2. Apply the mixture to the meat and wrap tightly with plastic wrap.\n3. Refrigerate for at least 8 hours or overnight.\n4. Store any leftover rub in an airtight jar or freeze.",
