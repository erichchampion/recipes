{
  "@type": "Recipe",
  "identifier": "zesty-herbed-mushroom-tomato-sauce",
  "name": "Zesty Herbed Mushroom-Tomato Sauce",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "sauces",
    "side dishes",
    "vegetarian"
  ],
  "recipeIngredient": [
    "32 ounces canned tomatoes, diced",
    "2 cups fresh mushrooms",
    "6 ounces tomato paste",
    "1/2 cup onion, chopped",
    "2 cloves garlic, minced",
    "2 tablespoons parmesan cheese, grated",
    "2 teaspoons dried oregano, crushed",
    "2 teaspoons brown sugar",
    "1 1/2 teaspoons dried basil, crushed",
    "1/2 teaspoon salt",
    "1/2 teaspoon fennel seed",
    "1/4 teaspoon crushed red pepper",
    "1 bay leaf",
    "12 ounces spaghetti, cooked and drained",
    "6 tablespoons parmesan cheese, grated"
  ],
  "recipeInstructions": "1. Combine all ingredients in a crockpot.\n2. Cover and cook on low for 8 to 10 hours or on high for 4 to 5 hours.\n3. Remove the bay leaf before serving.\n4. Serve over cooked pasta and sprinkle with additional parmesan cheese.",
  "url": null
}
