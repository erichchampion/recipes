  "recipeIngredient": [
    "2 cups Ketchup",
    "2 teaspoons A-1 steak sauce",
    "1 teaspoon Whole celery seed",
    "1 teaspoon Tabasco sauce",
    "2 tablespoons Soy sauce",
    "2/3 cup Dark brown sugar",
    "Juice of 2 lemons",
    "4 tablespoons Horseradish",
    "1/2 teaspoon Garlic powder",
    "1/2 teaspoon Sage",
    "1 teaspoon Salt",
    "1 cup Beer",
    "2 small onions finely chopped"
  ],
  "recipeInstructions": "1. Combine all ingredients in a saucepan.\n2. Bring the mixture to a boil.\n3. Reduce heat to medium-low and simmer, stirring constantly, for 5 minutes.",
