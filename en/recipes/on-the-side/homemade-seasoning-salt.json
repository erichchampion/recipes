  "recipeIngredient": [
    "3 tablespoons kosher salt",
    "2 teaspoons dried basil",
    "1 teaspoon dried fennel",
    "1 teaspoon paprika",
    "1 teaspoon turmeric",
    "1 teaspoon dried thyme",
    "1/4 teaspoon allspice",
    "1/4 teaspoon dry mustard",
    "1/4 teaspoon white pepper"
  ],
  "recipeInstructions": "1. In a small bowl, combine the kosher salt and all of the herbs.\n2. Stir until well combined.\n3. Store in an air-tight container.\nYield: 1/3 cup",
