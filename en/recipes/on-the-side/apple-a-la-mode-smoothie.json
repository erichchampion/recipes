  "recipeIngredient": [
    "2 cups nonfat vanilla frozen yogurt",
    "3/4 cup unsweetened applesauce",
    "1/4 cup chilled apple juice",
    "1 cup apple, diced and frozen",
    "1/2 teaspoon ground cinnamon",
    "1/4 teaspoon ground nutmeg"
  ],
  "recipeInstructions": "1. Combine the frozen yogurt, applesauce, and apple juice in a blender.\n2. Add the diced apple, cinnamon, and nutmeg.\n3. Blend until smooth.",
