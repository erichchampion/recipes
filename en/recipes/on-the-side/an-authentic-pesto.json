  "recipeIngredient": [
    "12 Walnuts, shelled",
    "2 tablespoons Pine nuts",
    "1 teaspoon Coarse salt",
    "4 (or 5) black peppercorns",
    "3 Garlic cloves",
    "4 tablespoons Butter",
    "3 cups Basil leaves",
    "4 ounces Grated Parmesan cheese",
    "4 ounces Grated Romano cheese",
    "-or added Parmesan cheese",
    "1.5 cups Olive oil"
  ],
  "recipeInstructions": "1. Place all ingredients, except for the 1 cup of black peppercorns, in a food processor.\n2. Process until finely ground.\n3. Add the remaining olive oil and blend for a few seconds until very smooth.",
