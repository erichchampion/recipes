  "recipeIngredient": [
    "1 1/2 cups fresh cranberries",
    "16 dried apricot halves, quartered",
    "3/4 cup brown sugar",
    "1/3 cup dried currants (or raisins)",
    "2 tablespoons fresh ginger root, minced",
    "2 tablespoons cranberry cocktail juice",
    "3/4 teaspoon ground cumin",
    "1/4 teaspoon cayenne pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a heavy saucepan.\n2. Cook over medium heat until the sugar is dissolved.\n3. Increase the heat and boil for 3 minutes.\n4. Transfer the mixture to a bowl and allow it to cool.",
