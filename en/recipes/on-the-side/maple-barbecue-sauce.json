  "recipeIngredient": [
    "3/4 cup maple syrup",
    "2 tablespoons chili sauce",
    "2 tablespoons cider vinegar",
    "1 1/2 tablespoon chopped onions",
    "1 tablespoon worcestershire sauce",
    "1 teaspoon salt",
    "1/2 teaspoon dry mustard",
    "1/2 teaspoon black pepper"
  ],
  "recipeInstructions": "1. In a bowl, combine all the ingredients.\n2. Brush the mixture onto top of 3 pounds of beef, pork or poultry.\n3. Baste frequently with sauce while baking.",
