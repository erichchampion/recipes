    "1/3 cup Chopped red bell pepper",
    "1/3 cup Chopped yellow bell pepper",
    "1/3 cup Chopped green bell pepper",
    "1/4 cup Olive oil",
    "2 tbsp Red wine vinegar",
    "1 tsp Mustard seeds",
    "1 tsp Ground coriander",
    "1 tsp Salt",
    "1 tsp Pepper",
    "1/4 cup Chopped fresh cilantro",
    "Tortilla chips"
