  "recipeIngredient": [
    "3/8 cup Olive oil",
    "1 cup Water",
    "3 tbsp Onion, grated",
    "1 tsp Garlic puree",
    "2 tsp Sugar",
    "1 tsp Salt",
    "2 tsp Paprika",
    "1 tsp Fresh ground black pepper",
    "1/3 tsp Dry mustard",
    "1 1/4 tsp Worcestershire sauce",
    "1 1/4 tsp Tabasco",
    "2 tbsp Tarragon vinegar"
