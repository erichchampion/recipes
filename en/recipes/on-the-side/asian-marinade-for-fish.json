  "recipeIngredient": [
    "1/4 cup Soy sauce or tamari",
    "2 tbsp Dark sesame oil",
    "2 tbsp Rice vinegar",
    "1 tbsp Minced garlic",
    "1 tbsp Minced ginger",
    "1 Scallion, sliced thin",
    "about 2 tb",
    "Ground black pepper to taste"
