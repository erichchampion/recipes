  "recipeIngredient": [
    "1 medium carrot, finely minced",
    "1 celery stalk, finely sliced",
    "1 tbsp minced garlic",
    "1 tbsp tomato paste",
    "1 1/2 tsp salt",
    "1 tsp freshly ground black pepper",
    "3 cups low-sodium chicken broth",
    "3 bay leaves",
    "1 sprig fresh thyme",
    "1/2 tsp dried thyme",
    "1 tbsp brown sugar",
    "1/2 cup cider vinegar",
    "2 tbsp ketchup",
    "1 tbsp dry mustard",
    "1 tsp Worcestershire sauce",
    "1/4 tsp ground clove",
    "1 t chili powder",
    "1/4 tsp cayenne pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a pot.\n2. Place over medium heat on the stove.\n3. Cook until reduced to 3/4 cup.\n4. Strain and use to glaze chicken, meat or fish while grilling.\n5. Makes 3/4 cup.",
