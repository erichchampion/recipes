  "recipeIngredient": [
    "1 cup Fresh lime juice",
    "2 tablespoons Olive oil",
    "2 tablespoons Dried oregano leaves",
    "2 teaspoons Salt",
    "2 tablespoons Chopped cilantro",
    "2 tablespoons Ground black pepper",
    "2 tablespoons Diced yellow onion",
    "1 teaspoon Red pepper flakes",
    "1 teaspoon Fresh chopped garlic"
  ],
  "recipeInstructions": "1. In a bowl, combine all ingredients.\n2. Whisk or shake until well mixed and emulsified.\n3. Use the marinade for poultry, seafood, or vegetables.\n4. Allow marinating time of 30 minutes to 2 hours.",
