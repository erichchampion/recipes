  "recipeIngredient": [
    "1/4 cup fresh lime juice",
    "3 tablespoons Nam Pla (fish sauce)",
    "2 tablespoons vegetable oil",
    "5 teaspoons sugar",
    "1 tablespoon mint leaves, chopped",
    "2 cloves garlic, minced",
    "1/2 teaspoon salt"
  ],
  "recipeInstructions": "1. Mix all ingredients together in a bowl.\n2. Stir until the sugar dissolves completely.",
