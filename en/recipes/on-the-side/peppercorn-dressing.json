  "recipeIngredient": [
    "2 tablespoons Finely chopped shallots",
    "2 tablespoons Vinegar",
    "1 1/4 cups Mayonnaise",
    "1/4 teaspoon Salt",
    "1/2 teaspoon Garlic powder",
    "1/4 cup Sour cream",
    "1 tablespoon Lemon juice",
    "1/4 cup Cream or half-and-half",
    "3/4 teaspoon Worcestershire sauce",
    "1 1/2 teaspoons Finely ground pepper",
    "2 1/2 teaspoons Cracked peppercorns",
    "1/4 cup Freshly grated Parmesan"
  ],
  "recipeInstructions": "Combine all ingredients in a large jar. Seal tightly and refrigerate for at least 24 hours to allow flavors to meld before using. Makes approximately 1 pint.",
