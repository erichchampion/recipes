  "recipeIngredient": [
    "1 2.5 oz package herb soup mix",
    "1 8 oz package cream cheese, softened",
    "1/2 cup butter or margarine, softened",
    "2 tbsp milk",
    "1 tbsp white wine vinegar",
    "1 garlic clove, pressed",
    "1 tbsp grated onion",
    "1/2 tsp freshly ground pepper"
  ],
  "recipeInstructions": "1 Combine all ingredients in a large bowl; stir well.\n2 Cover and chill. Let stand at room temperature 30 minutes before serving with crackers and fresh vegetables.\n3 Yield: 2 cups.",
