  "recipeIngredient": [
    "2 tablespoons Butter (25 mL)",
    "1/2 cup Onion, chopped (125 mL)",
    "3/4 cup Ketchup (175 mL)",
    "1/2 cup Beef stock (125 mL)",
    "2 tablespoons Worcestershire Sauce (25 mL)",
    "2 tablespoons Lemon juice (25 mL)",
    "2 tablespoons Red wine vinegar (25 mL)",
    "1/4 cup Brown sugar (50 mL)",
    "1 1/2 teaspoons Dry mustard (7 mL)",
    "1 1/2 teaspoons Black peppercorns, cracked",
    "or black pepper (7 mL)"
  ],
  "recipeInstructions": "1. In a saucepan, cook onion in butter until softened.\n2. Add remaining ingredients; bring to boil.\n3. Reduce heat and simmer for 15-20 minutes.\nMakes 1 1/2 cups (375 mL)",
