  "recipeIngredient": [
    "1/2 cup Ketchup",
    "2 cups Water",
    "1/4 cup Lemon juice",
    "1/4 cup Dark vinegar",
    "1/2 teaspoon Smoked salt",
    "1 large Onion, wedge cut",
    "1 cup Corn oil",
    "3 tablespoons Soy sauce",
    "2 tablespoons French's prepared mustard",
    "1 tablespoon Garlic salt",
    "1 tablespoon Coarse ground black pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a bowl.\n2. Submerge steaks in the mixture and refrigerate for 24 hours, covered.\n3. After 24 hours, drain the steaks well.\n4. Broil as usual.",
