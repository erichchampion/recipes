  "recipeIngredient": [
    "1/2 cup Butter",
    "1/2 cup Lemon Juice",
    "2 tablespoons Worcestershire Sauce",
    "1 small clove Garlic, minced",
    "1/2 teaspoon Black Pepper",
    "1/2 teaspoon Dry Mustard",
    "2 drops Tabasco",
    "Salt to taste"
  ],
  "recipeInstructions": "1. Combine all ingredients in a bowl.\n2. Heat until the butter melts.\n3. If desired, add lemon juice.\n4. Serve with steak and salt.",
