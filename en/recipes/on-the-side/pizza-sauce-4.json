  "recipeIngredient": [
    "2 tablespoons olive oil",
    "1/2 teaspoon salt",
    "1/4 teaspoon pepper",
    "1 teaspoon oregano",
    "1/2 teaspoon parsley flakes",
    "1 teaspoon Italian seasoning",
    "12 ounces tomato paste",
    "15 ounces tomato sauce",
    "1 cup water (the smaller can)",
    "1/8 teaspoon garlic powder",
    "1 teaspoon spaghetti sauce seasoning",
    "1/2 teaspoon sugar"
  ],
  "recipeInstructions": "1. In a large pot, combine all ingredients.\n2. Stir to mix well.\n3. Place the pot on the stove and turn the heat to low.\n4. Simmer for 30 to 45 minutes.\n5. Remove from heat and allow the mixture to cool completely before using.",
