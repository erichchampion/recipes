  "recipeIngredient": [
    "1/4 cup Kosher or Sea Salt",
    "1 tablespoon Accent",
    "1 teaspoon Dill weed",
    "1 teaspoon Black pepper",
    "1 teaspoon Onion powder",
    "1/4 teaspoon Garlic salt",
    "1/4 teaspoon Curry powder",
    "Grated rind of 1 Lemon",
    "1/4 teaspoon Chili powder",
    "1/4 teaspoon Paprika",
    "1/4 teaspoon Oregano leaf",
    "1/4 teaspoon Dried marjoram leaves",
    "1/4 teaspoon Rubbed sage"
  ],
  "recipeInstructions": "1. Mix all ingredients and store in a pepper grinder or put through a blender to a very fine powder, using high speed.\n2. Makes about 1/2 cup.\n3. Keeps indefinitely at room temperature.",
