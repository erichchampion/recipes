  "recipeIngredient": [
    "8 oz Nonfat vanilla yogurt",
    "1/2 cup Canned unsweetened pineapple",
    "-(chunks) drained and chilled",
    "1/2 cup Canned sliced peaches",
    "-(unsweetened)",
    "-- drained and chilled",
    "5 Ice cubes",
    "1 Banana, peeled",
    "-- cut into 1-inch pieces",
    "-- and frozen",
    "1/4 cup Skim milk"
