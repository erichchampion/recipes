  "recipeIngredient": [
    "1 cup Cider vinegar",
    "1 cup Water",
    "2 tbsp Lemon juice",
    "2 Garlic cloves",
    "1/4 tsp Ground pepper; optional",
    "1/2 tsp Celery seed",
    "1/2 Cucumber; cut into chunks",
    "1 small Onion; cut into chunks",
    "1/2 tsp Dill weed",
    "1 tbsp Parsley"
  ],
  "recipeInstructions": "1. Measure all ingredients.\n2. Add the ingredients to a blender jar.\n3. Blend until smooth.\n4. Transfer to a container and refrigerate.\n5. Keeps well in the refrigerator.",
