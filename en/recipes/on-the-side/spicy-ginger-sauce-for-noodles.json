  "recipeIngredient": [
    "3 tablespoons Vegetable oil",
    "3 tablespoons Rice vinegar",
    "1½ tablespoons Low-sodium soy sauce",
    "1 tablespoon Oriental sesame oil",
    "2 teaspoons Minced peeled fresh ginger",
    "2 Garlic cloves, minced",
    "1 teaspoon Sugar",
    "1/2 teaspoon Chili oil -OR-",
    "1/4 teaspoon Dried crushed red pepper",
    "2 Green onions, thinly sliced",
    "1 Carrot, peeled, shredded",
    "½ Cucumber (peeled, seeded, and chopped)",
    "¼ cup Chopped fresh cilantro"
  ],
  "recipeInstructions": "[This sauce pairs well with Japanese noodles such as udon. Serve the finished dish chilled.]\n1. Whisk all ingredients together in a large bowl.\n2. Refrigerate until ready to use.",
