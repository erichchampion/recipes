  "recipeIngredient": [
    "4 cups Chablis wine",
    "1 cup Green crème de menthe",
    "1 tablespoon Onion powder",
    "1 teaspoon Dried mint (crushed)",
    "2 tablespoons Louisiana hot sauce",
    "1 cup Soy sauce",
    "2 tablespoons Olive oil"
  ],
  "recipeInstructions": "1. Mix all ingredients.\n2. Marinate lamb or goat for 6 to 12 hours.\n3. Use the marinade as a basting sauce while cooking.",
