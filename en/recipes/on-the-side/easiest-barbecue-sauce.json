  "recipeIngredient": [
    "3 tablespoons Catsup",
    "2 tablespoons Vinegar",
    "1 teaspoon Lemon juice",
    "2 tablespoons Worcestershire sauce",
    "4 tablespoons Water",
    "2 tablespoons Cooking oil",
    "3 tablespoons Brown sugar",
    "1 teaspoon Salt",
    "1 teaspoon Dry mustard",
    "1 teaspoon Chili powder",
    "1 teaspoon Paprika",
    "1/2 teaspoon Red pepper"
  ],
  "recipeInstructions": "1. Combine all ingredients in a quart jar.\n2. Shake well and refrigerate until ready to use as a basting sauce for barbecue chicken, beef or pork.",
