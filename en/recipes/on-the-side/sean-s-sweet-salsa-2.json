    "1 tbsp ginger root - diced",
    "1/2 medium Spanish onion - diced",
    "1 splash Rose's lime juice",
    "1 tangerine - peeled and diced",
    "1/2 pear - cored and diced",
    "4 strips dry mango - diced",
