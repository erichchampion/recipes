  "recipeIngredient": [
    "1 teaspoon Salt",
    "3 cups Canned beef broth",
    "1/4 cup White vinegar",
    "1/2 cup Worcestershire sauce",
    "1 cup Tomato paste",
    "1/2 cup Brown sugar",
    "1/2 cup Honey",
    "1 tablespoon Chili powder",
    "3 tablespoons Paprika",
    "1 tablespoon Sage",
    "1 1/2 teaspoons Cayenne pepper",
    "1 teaspoon Turmeric",
    "3 cloves Garlic, crushed"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large saucepan.\n2. Bring the mixture to a simmer.\n3. Simmer for 1 1/2 hours, stirring occasionally until the sauce has thickened and reduced slightly.",
