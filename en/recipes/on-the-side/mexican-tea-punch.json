  "recipeIngredient": [
    "2 cups Tequila",
    "2 cups Tea (strong, cold)",
    "1 cup Pineapple Juice",
    "1/4 cup Honey",
    "1/4 cup Lime Juice",
    "1/4 cup Lemon Juice",
    "1 1/2 teaspoons Ground Cinnamon",
    "1 1/2 teaspoons Aromatic Bitters"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large punch bowl.\n2. Refrigerate the mixture until chilled, about 2 hours.\n3. Just before serving, stir the punch well over ice.\n4. Serve and enjoy.",
