  "recipeIngredient": [
    "3 Eggs",
    "15 oz Canned milk or \"Eagle Brand\"",
    "1/2 pint Whipping cream",
    "1/2 tsp Coconut extract",
    "3 tbsp Chocolate syrup",
    "13 oz Scotch Whiskey, (mickey)"
  ],
  "recipeInstructions": "1. Combine all ingredients in a blender.\n2. Blend for 1 minute.\n3. Let stand overnight.\n4. Bottle the next day. No waiting time.",
