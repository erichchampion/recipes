  "recipeIngredient": [
    "2 tablespoons Red wine vinegar",
    "1/8 teaspoon Garlic powder",
    "2 tablespoons Acceptable vegetable oil",
    "1/8 teaspoon Sugar",
    "4 tablespoons Water",
    "1/2 tablespoon Fresh lemon juice",
    "1/8 teaspoon Freshly ground black pepper"
  ],
  "recipeInstructions": "1. In a jar with a tight-fitting lid, combine all ingredients.\n2. Shake well and refrigerate. Makes 1/2 cup.\n(Attribution: Am. Heart Assoc. Low-Salt Cookbook 1990)",
