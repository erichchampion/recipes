  "identifier": "suet-or-carrot-pudding",
  "name": "Suet or Carrot Pudding",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "On the Side",
  "keywords": [
    "puddings",
    "side dishes",
    "vegetables"
  ],
  "recipeIngredient": [
    "2 cups Carrot, cooked and mashed",
    "1 cup Suet, chopped",
    "1 cup Molasses",
    "1 Egg",
    "1 teaspoon Baking soda",
    "Dissolved in:",
    "1/4 cup Water, hot",
    "2 tablespoons Brown sugar",
    "1/4 teaspoon Salt",
    "1 tablespoon Lemon zest",
    "1 teaspoon Allspice",
    "1 teaspoon Cinnamon",
    "1 teaspoon Nutmeg",
    "1 teaspoon Cloves",
    "1/2 cup Raisins",
    "1/2 cup Currants",
    "1/2 cup Citron, chopped",
    "1/2 cup Flour"
  ],
  "recipeInstructions": "1. Mix all the ingredients together, adding the dissolved baking soda last.\n2. Place the mixture into a buttered mold and steam for 3 hours. You may need to add extra flour to thicken the batter.",
  "url": null
}
