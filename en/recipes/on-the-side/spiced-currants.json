  "recipeIngredient": [
    "3 pounds Ripe currants",
    "2 pounds Sugar",
    "1 tablespoon Cinnamon",
    "1 teaspoon Allspice",
    "1 cup Vinegar",
    "1 cup Water",
    "1 teaspoon Cloves"
  ],
  "recipeInstructions": "1. Wash the currants.\n2. Remove stems from the currants.\n3. Add remaining ingredients to the currants.\n4. Boil gently for 30 minutes.",
