    "3/4 cup vinegar",
    "1 tsp salt",
    "1/2 tsp paprika",
    "1/2 tsp pepper",
    "1/2 cup sugar",
    "1 tsp dry mustard",
    "1/2 cup chopped onion",
    "1 tsp minced garlic (from 1 clove)",
