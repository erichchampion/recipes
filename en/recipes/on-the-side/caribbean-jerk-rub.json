  "recipeIngredient": [
    "1 tablespoon sugar",
    "1 tablespoon onion powder",
    "1 tablespoon dried thyme",
    "2 teaspoons dried allspice",
    "2 teaspoons ground black pepper",
    "1 teaspoon cayenne pepper",
    "1 teaspoon salt",
    "3/4 teaspoon ground nutmeg",
    "1/4 teaspoon ground cloves"
