  "recipeIngredient": [
    "1 cup cheddar cheese",
    "1/4 cup half and half",
    "2 tablespoons cider vinegar",
    "1/4 teaspoon kosher salt",
    "4 ounces cream cheese",
    "1 tablespoon garlic"
  ],
  "recipeInstructions": "1. Combine all ingredients in a food processor.\n2. Process until smooth.\n3. Cover and chill for 2-48 hours.\n4. Serve slightly chilled.",
