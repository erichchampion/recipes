  "recipeIngredient": [
    "1 1/3 cups Salad Oil",
    "1/2 cup Vinegar",
    "1/4 cup Parmesan Cheese (Grated)",
    "1 tbsp Sugar",
    "2 tsp Salt",
    "1 tsp Celery Salt",
    "1/2 tsp White Pepper",
    "1/2 tsp Dry Mustard",
    "1/4 tsp Paprika",
    "1 medium Garlic Clove (Minced)"
