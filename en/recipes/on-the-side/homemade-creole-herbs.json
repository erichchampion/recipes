  "recipeIngredient": [
    "1/4 cup dried marjoram",
    "1/4 cup dried thyme",
    "1/4 cup dried savory",
    "5 medium bay leaves, crushed",
    "2 tablespoons dried oregano",
    "1 tablespoon dried rosemary",
    "1 teaspoon dried lavender blossoms",
    "1 teaspoon dried tarragon",
    "1 teaspoon red pepper flakes"
  ],
  "recipeInstructions": "1. Combine all ingredients in a mixing bowl and stir well.\n2. Store the mixture in an airtight container.\nNotes: Homemade alternative to Herbes de Provence",
