  "recipeIngredient": [
    "1 Cantaloupe, honeydew or",
    "-combination - peeled,",
    "-seeded, cut into large",
    "-chunks and chilled",
    "1/2 cup Ice water",
    "1/4 cup Tightly packed mint leaves",
    "8 Ice cubes",
    "2 T Freshly squeezed lime juice",
    "1/8 t Fine sea salt (optional)"
  ],
  "recipeInstructions": "1. Add all the ingredients to a blender.\n2. Blend until smooth.\n3. Serve immediately, as the cooler will separate upon standing.\n4. Makes about 3 1/2 cups.",
