  "recipeIngredient": [
    "1 cup creole mustard",
    "1 cup red wine vinegar",
    "3/4 cup red chile sauce",
    "1/4 cup prepared horseradish",
    "2 teaspoons dry mustard",
    "3 cups olive oil",
    "1 cup capers, drained",
    "12 egg yolks",
    "3 cups celery, finely diced",
    "3/4 cup scallions, finely chopped",
    "3/4 cup mayonnaise",
    "2 teaspoons garlic powder",
    "1/2 teaspoon kosher salt",
    "1/2 teaspoon freshly ground white pepper",
    "1/4 teaspoon cayenne"
  ],
  "recipeInstructions": "1. Combine all ingredients in a food processor.\n2. Process until smooth and well blended.\n3. Cover and chill for 2-96 hours before serving, ensuring it is well chilled.",
