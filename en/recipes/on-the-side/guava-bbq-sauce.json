  "recipeIngredient": [
    "2 cans guava nectar (11.5 oz each)",
    "1 1/2 cups onion, chopped",
    "2/3 cup guava jelly",
    "1/3 cup dry sherry",
    "1/4 cup molasses (mild-flavored - light)",
    "3 tablespoons red wine vinegar",
    "2 tablespoons tomato paste",
    "1 1/2 tablespoons garlic, chopped",
    "1 tablespoon ground cumin",
    "2 teaspoons dry mustard"
  ],
  "recipeInstructions": "1. Whisk all ingredients in a large saucepan.\n2. Boil mixture, whisking until jelly dissolves.\n3. Reduce heat and simmer until sauce is reduced to 3 cups.\n4. Cool.",
