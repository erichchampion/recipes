  "recipeIngredient": [
    "3 cups grated zucchini",
    "1 small onion, chopped",
    "1 package Bisquick",
    "4 eggs",
    "1/2 cup vegetable oil",
    "1/2 cup grated Parmesan cheese",
    "1/2 teaspoon dried parsley",
    "1/2 teaspoon dried marjoram",
    "1/4 teaspoon salt",
    "1/4 teaspoon ground pepper"
  ],
  "recipeInstructions": "1. Preheat the oven to 350 degrees F.\n2. In a large bowl, mix all ingredients until well combined.\n3. Pour the mixture into a greased pie pan.\n4. Bake for 30 minutes or until golden brown.",
