  "recipeIngredient": [
    "2 1/2 cups Cooked Brown Rice",
    "1 cup Lowfat Cottage Cheese -or-",
    "1/2 cup Lowfat Milk",
    "3 Green Onions (scallions), chopped",
    "1 tablespoon Dried Dill",
    "1/4 cup Parmesan Cheese, grated"
  ],
  "recipeInstructions": "1. In a mixing bowl, combine all ingredients.\n2. Pour the mixture into a lightly oiled casserole dish.\n3. Bake in a 350-degree oven for 15 to 20 minutes.\nServes 4",
