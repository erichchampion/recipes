{
  "@type": "Recipe",
  "identifier": "mild-fish-pickle",
  "name": "Mild Fish Pickle",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "pickles",
    "relishes",
    "spices"
  ],
  "recipeIngredient": [
    "3 oz Tuna",
    "3 oz Salmon",
    "3 oz Anchovy",
    "2 tsp White wine",
    "1 tbsp Vinegar",
    "1/2 tsp Mustard seed",
    "1/2 tsp Oregano",
    "1/2 tsp Celery seed (or Lovage)",
    "1 tbsp Olive oil",
    "1/2 tsp Honey",
    "1 pinch Basil",
    "1/4 tsp Thyme",
    "1 Mint leaf, finely chopped"
  ],
  "recipeInstructions": "1. In a mixing bowl, thoroughly combine all ingredients.\n2. Transfer the mixture to a glass jar and store in the refrigerator for up to 2 weeks.\n3. After 2 weeks, discard the pickle and prepare a new batch.",
  "url": null
}
