    "1 Bell pepper, chopped",
    "1/8 teaspoon Cayenne",
    "1 Onion, chopped",
    "1/2 teaspoon Salt",
    "2 Medium tomatoes, chopped",
    "4 ounces Smoked Sausage, chopped",
    "1 cup Chopped celery",
