  "recipeIngredient": [
    "1 Lime Jello",
    "2 cups Boiling Water",
    "1 Can Pimentos, drained",
    "8 oz Cream Cheese",
    "1 May substitute Cottage Cheese",
    "3 Tablespoons Horseradish, moistened",
    "1 Cup Nuts, finely chopped",
    "1/4 Teaspoon Salt",
    "1 Lemon Jello",
    "1 Can Crushed Pineapple with Juice",
    "1 Can Sweetened Condensed Milk",
    "3 Tablespoons Lemon Juice"
  ],
  "recipeInstructions": "1. Dissolve the jellies in boiling water.\n2. Add the remaining ingredients and mix well.\n3. Pour the mixture into a 9x13 inch dish.\n4. Refrigerate until set.",
