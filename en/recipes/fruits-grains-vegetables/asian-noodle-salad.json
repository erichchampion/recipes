  "identifier": "asian-noodle-salad",
  "name": "Asian Noodle Salad",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "salads"
  ],
  "recipeIngredient": [
    "6 ounces Chinese-style egg noodles",
    "1/3 cup chopped green onions (about 3 medium)",
    "2 tablespoons frozen apple juice concentrate",
    "1 tablespoon balsamic vinegar",
    "1 tablespoon reduced-sodium soy sauce",
    "2 teaspoons finely chopped gingerroot",
    "1/2 teaspoon sesame oil",
    "1 clove garlic, finely chopped"
  ],
  "recipeInstructions": "Cook Chinese egg noodles as directed on package, omitting salt. Drain and toss with remaining ingredients. Cover and refrigerate for about 2 hours or until chilled.",
