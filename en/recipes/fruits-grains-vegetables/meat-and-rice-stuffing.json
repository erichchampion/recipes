  "recipeIngredient": [
    "3 large onions, coarsely grated",
    "1 lb minced meat",
    "1 cup parsley, finely chopped",
    "1 cup dill, finely chopped",
    "1 tomato, grated or diluted",
    "2 tbsp butter",
    "1/4 cup rice (short grain)",
    "Salt and pepper to taste",
    "1 cup fresh mint, finely chopped",
    "1/2 cup water",
    "1 tbsp tomato paste",
    "1/4 cup cold water"
