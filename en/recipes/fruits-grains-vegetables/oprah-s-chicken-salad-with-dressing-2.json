  "name": "Oprah's Chicken Salad with Dressing",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "chicken",
    "salads"
  ],
  "recipeIngredient": [
    "1 1/2 cups Chicken breast -- skinless, boneless",
    "1/4 cup Peas",
    "1 tbsp Golden raisins",
    "1/4 cup Carrots -- shredded",
    "1 cup Red cabbage -- shredded",
    "1/4 cup Apples -- diced",
    "1/4 cup Scallions -- sliced",
    "1/4 cup Celery -- diced",
    "DRESSING-----",
    "1/8 tsp Celery seed",
    "1 cup Nonfat yogurt",
    "1 tbsp Nonfat mayonnaise",
    "3 tsp Curry powder (optional)",
    "3 tbsp Lemon juice",
    "1 tbsp Dijon mustard",
    "2 tbsp Shallots -- diced",
    "Black pepper"
  ],
  "recipeInstructions": "1. Toss all salad ingredients together.\n2. Put dressing ingredients in a blender and blend until smooth.\n3. Serve the blended dressing over the salad.",
