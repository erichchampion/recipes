  "name": "Carrot Salad",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "salads"
  ],
  "recipeIngredient": [
    "5 cups Carrots, sliced",
    "1 cup Tomato soup",
    "3/4 cup White vinegar",
    "1/2 cup Oil",
    "1 tsp Dry mustard",
    "1 tsp Salt",
    "1 tsp Worcestershire sauce",
    "1 Onion, cut into rings",
    "1 Green pepper, large",
    "3/4 cup White sugar"
  ],
  "recipeInstructions": "1. Parboil carrots for about 12 - 15 minutes.\n2. Add the rest of the ingredients and marinate in the refrigerator for at least 24 hours.\n3. Serve chilled.",
