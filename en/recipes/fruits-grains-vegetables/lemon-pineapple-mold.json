  "recipeIngredient": [
    "2 packages lemon jello (3 oz each)",
    "1 can pineapple chunks (small)",
    "3 2/3 cups water and pineapple juice",
    "1/8 cup vinegar",
    "1/2 cup celery, sliced thin",
    "1 jar pimiento (small)",
    "2 tablespoons green pepper",
    "1/2 small cucumber",
    "Dash salt",
    "Little grated onion"
  ],
  "recipeInstructions": "1. Mix all ingredients together.\n2. Pour the mixture into a mold.\n3. Place the mold in the refrigerator until set.",
