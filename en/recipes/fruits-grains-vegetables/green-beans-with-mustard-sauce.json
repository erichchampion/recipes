  "name": "Green Beans with Mustard Sauce",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "vegetables"
  ],
  "recipeIngredient": [
    "1 Can French cut green beans",
    "1/3 cup Butter",
    "2 teaspoons Prepared mustard",
    "1 teaspoon Sugar",
    "1/2 teaspoon Salt",
    "2 teaspoons Lemon juice"
  ],
  "recipeInstructions": "1. Cream the butter.\n2. Add the remaining ingredients and blend well.\n3. Stir the mixture into hot green beans.",
