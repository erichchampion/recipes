  "recipeIngredient": [
    "1 pound fresh green beans, trimmed",
    "1/4 cup chopped fully cooked ham",
    "1/4 cup butter",
    "1/4 cup water",
    "1 garlic clove, minced",
    "1/2 teaspoon salt",
    "1/4 teaspoon pepper"
  ],
  "recipeInstructions": "1. In a saucepan, combine all ingredients.\n2. Cover and simmer for 15-20 minutes or until beans are tender.\nYIELD: 4 servings",
