  "recipeIngredient": [
    "2 cups cooked lobster meat",
    "Lettuce",
    "1/3 cup olive oil",
    "2 tbsp wine vinegar",
    "1/2 tsp salt",
    "6 drops hot sauce",
    "1/4 tsp dry mustard",
    "1/2 cup mayonnaise",
    "2 cups thinly sliced celery",
    "1 small onion, minced"
  ],
  "recipeInstructions": "1. Cut the lobster meat into pieces and arrange on lettuce leaves.\n2. Combine the remaining ingredients in a bowl and pour over the lobster.\n3. Chill for 1 hour or more.",
