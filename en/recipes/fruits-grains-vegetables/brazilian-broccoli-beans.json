    "3 oz broccoli florets (bite-size pieces)",
    "3 oz snap beans (bite-size pieces)",
    "3 oz kale (coarsely chopped)",
    "3 oz cooked soybeans",
    "1½ oz Brazil nuts (chopped)",
    "1½ tbsp soy oil",
    "½ tsp garlic (minced)",
    "1½ oz fresh chives (minced)",
    "¼ tsp tarragon",
    "½ tsp salt"
