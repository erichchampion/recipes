  "recipeIngredient": [
    "2 cups cooked black eyed peas",
    "2 cups cooked Texmati rice",
    "1 cup diced tomatoes",
    "1/2 cup diced zucchini",
    "1/2 cup diced country ham",
    "1/4 cup minced shallots",
    "2 tablespoons minced garlic",
    "1/4 cup minced scallion whites",
    "2 teaspoons chopped thyme",
    "2 tablespoons chopped cilantro",
    "2 tablespoons chopped basil",
    "2 canned chipotle chilies, chopped",
    "2 tablespoons malt vinegar",
    "2 tablespoons lemon juice",
    "1/3 cup extra virgin olive oil",
    "Salt to taste"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large bowl.\n2. Mix well until all ingredients are evenly distributed.\n3. Allow the salad to marinate for at least two hours for best flavor.\n4. To serve, place 1/4 cup of greens on each plate.\n5. Top with 1/3 cup of the black eyed pea rice salad.",
