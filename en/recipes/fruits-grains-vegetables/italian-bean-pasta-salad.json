  "recipeIngredient": [
    "2 cups Cooked Amaranth Anasazi Beans",
    "2 cups Cooked spinach noodles",
    "1/2 cup Chopped onion",
    "1 medium Chopped tomato",
    "1/4 cup Chopped bell pepper",
    "1 tablespoon Amaranth Sesame Seed",
    "1/8 cup Am refined Olive Oil",
    "1/8 cup Lemon juice",
    "1 teaspoon Garlic powder",
    "1/4 teaspoon Oregano",
    "1/4 teaspoon Basil",
    "1/4 teaspoon Thyme",
    "1/4 teaspoon Sea salt (optional)"
  ],
  "recipeInstructions": "1. Gently mix all ingredients together in a large mixing bowl.\n2. Refrigerate until cold and serve.\n3. Allowing the mixture to set for an hour before serving will enhance the flavor.",
