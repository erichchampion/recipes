  "identifier": "italian-bean-pasta-salad",
  "name": "Italian Bean & Pasta Salad",
  "recipeCuisine": "Europe",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "pasta",
    "salads"
