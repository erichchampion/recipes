  "recipeIngredient": [
    "2 1/2 cups Cooked AM Bit-O-Barley",
    "1/2 cup Ground raw cashews",
    "1 tbsp AM Unrefined Vegetable Oil",
    "1 tablespoon Sage",
    "1 1/2 teaspoons Poultry seasoning",
    "1 tablespoon Celery seed",
    "3 tablespoons Onion flakes",
    "1 cup Tomato puree",
    "1 can Cream of Mushroom soup",
    "1 1/2 cups AM Wheat Germ",
    "Sea salt to taste (optional)"
  ],
  "recipeInstructions": "1. Mix all ingredients and bake in an oiled casserole dish at 350°F for one hour.",
