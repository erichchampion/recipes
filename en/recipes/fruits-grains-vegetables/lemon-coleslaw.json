{
  "@type": "Recipe",
  "identifier": "lemon-coleslaw",
  "name": "Lemon Coleslaw",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "salads"
  ],
  "recipeIngredient": [
    "1/2 cup Mayonnaise",
    "1/4 cup Fresh lemon juice",
    "2 tbsp Olive oil",
    "1 tbsp White wine vinegar",
    "1 tsp Salt",
    "1/2 tsp Pepper",
    "1/2 Red bell pepper (cut into matchsticks)",
    "1/4 Red onion (cut into matchsticks)",
    "2 tbsp Chopped fresh parsley",
    "1/2 cup Sour cream",
    "2 tbsp Dijon mustard",
    "2 tbsp Sugar",
    "1 tbsp Prepared horseradish",
    "1/2 tsp Celery seeds",
    "8 cups Shredded cabbage (about 1 1/2 heads)",
    "1/2 Green bell pepper (cut into matchsticks)",
    "1 Carrot, shredded",
    "2 tsp Grated lemon peel"
  ],
  "recipeInstructions": "1. In a bowl, combine the first 11 ingredients and whisk to blend.\n2. Refrigerate the dressing until cold. It can be prepared up to one day in advance.\n3. In a large bowl, mix the cabbage, bell peppers, onion, carrot, parsley, and lemon peel.\n4. Toss with enough dressing to season to taste and serve.",
  "url": null
