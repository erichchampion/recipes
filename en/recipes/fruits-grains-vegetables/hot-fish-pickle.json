    "1 tbsp Vinegar",
    "1 tbsp Olive oil",
    "1 Clove garlic, crushed",
    "1/4 tsp Pepper",
    "2 tsp Parsley",
    "1/4 tsp Rosemary, ground",
    "1/4 tsp Sage",
    "1 Mint leaf, finely chopped",
    "1 pinch Basil"
