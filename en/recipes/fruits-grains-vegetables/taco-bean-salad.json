{
  "@type": "Recipe",
  "identifier": "taco-bean-salad",
  "name": "Taco Bean Salad",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "main dish",
    "salads"
  ],
  "recipeIngredient": [
    "3 cups Cooked Pinto Beans (drained)",
    "2 tablespoons Unrefined Olive Oil",
    "1 small Onion, chopped",
    "1 Green Bell Pepper, chopped",
    "1 Tomato, chopped",
    "2 teaspoons Chili Powder",
    "1/2 teaspoon Ground Cumin",
    "1/4 teaspoon Cayenne Pepper (optional)",
    "1/4 teaspoon Oregano",
    "1/4 teaspoon Sea Salt (optional)",
    "1 Celery Stalk, chopped finely",
    "1/2 cup Sour Cream or Plain Yogurt",
    "1 D Tablespoon Tabasco Sauce (optional)"
  ],
  "recipeInstructions": "1. Soak the beans overnight.\n2. Cook until tender and drain.\n3. Combine all ingredients in a bowl and mix well.\n4. Serve with lettuce and corn chips.",
