  "name": "Our Best Baked Beans",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "beans"
  ],
  "recipeIngredient": [
    "5 slices bacon, fried and crumbled",
    "2 16 oz cans baked beans, drained",
    "1/2 green pepper, seeded and chopped",
    "1/2 medium onion, chopped",
    "1 1/2 teaspoons prepared mustard",
    "1/2 cup ketchup",
    "1/2 cup hickory-smoke barbecue sauce",
    "1/2 cup packed brown sugar"
  ],
  "recipeInstructions": "1. Mix all ingredients in a Crock-Pot.\n2. Cover and cook on Low for 8 to 12 hours, or on High for 3 to 4 hours.\n3. Serves 6 to 8.",
