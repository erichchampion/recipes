{
  "@type": "Recipe",
  "identifier": "marinated-tomatoes",
  "name": "Marinated Tomatoes",
  "recipeCuisine": "Europe",
  "recipeCategory": "Fruits, Grains & Vegetables",
  "keywords": [
    "tomatoes",
    "vegetables"
  ],
  "recipeIngredient": [
    "4 large tomatoes",
    "1 cup vegetable oil",
    "1/4 cup wine vinegar",
    "1/4 tsp dry mustard",
    "1 t salt",
    "1/4 tsp black pepper",
    "1 large garlic clove, minced",
    "1 tbsp fresh basil, chopped",
    "2 thyme sprigs, chopped",
    "1 marjoram sprig, chopped",
    "1 tbsp scallion, minced"
  ],
  "recipeInstructions": "1. Peel and slice the tomatoes.\n2. Place tomato slices in a serving bowl.\n3. Combine remaining ingredients and pour over the tomatoes.\n4. Toss lightly.\n5. Chill for 1 hour or longer before serving.",
  "url": null
}
