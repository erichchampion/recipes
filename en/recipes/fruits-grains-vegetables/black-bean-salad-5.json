    "1 cup Adzuki beans (or red beans) -- cooked",
    "2 onions, sliced",
    "2 green peppers, sliced",
    "2 stalks celery, sliced",
    "2 green onions, thinly sliced",
    "2 cups oil",
    "1/2 cup honey",
    "2 cloves garlic, pressed",
    "1 lemon, juiced",
    "1 cup white wine",
    "1 teaspoon oregano",
    "1 tablespoon parsley"
