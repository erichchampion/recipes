  "recipeIngredient": [
    "2 medium cucumber, sliced thin",
    "4 green onions, sliced thin",
    "3 small tomatoes, sliced",
    "2 tablespoons fresh parsley, snipped",
    "1/4 cup sour cream",
    "1/4 teaspoon prepared mustard",
    "2 tablespoons fresh dill, minced",
    "1 tablespoon vinegar",
    "1 tablespoon milk",
    "1/2 teaspoon salt",
    "1/8 teaspoon pepper"
  ],
  "recipeInstructions": "1. In a bowl, combine all salad ingredients.\n2. Combine dressing ingredients; pour over cucumber mixture and toss gently.\n3. Cover and chill for at least an hour.\nMakes 4 to 6 servings.",
