  "recipeIngredient": [
    "1 cup sugar",
    "1 stick butter",
    "2 eggs, beaten",
    "2 cups persimmon pulp",
    "2 cups flour",
    "1/2 teaspoon salt",
    "1 teaspoon baking soda",
    "1/2 teaspoon cinnamon",
    "1/2 teaspoon nutmeg",
    "1/2 teaspoon ground cloves",
    "1 cup chopped nuts",
    "1 cup raisins"
  ],
  "recipeInstructions": "1. Beat in eggs and persimmon pulp.\n2. Gradually add the remaining ingredients, mixing well after each addition.\n3. Drop batter onto a baking sheet.\n4. Bake for 10-12 minutes at 350°F.",
