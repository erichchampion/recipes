  "name": "Dishpan Cookies",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Sweets & Desserts",
  "keywords": [
    "baked goods",
    "cookies",
    "desserts"
  ],
  "recipeIngredient": [
    "2 cups Brown sugar",
    "2 cups White sugar",
    "1 lb Softened butter or margarine",
    "4 cups Flour",
    "4 Eggs",
    "1/2 tsp Salt",
    "2 tsp Baking soda",
    "2 tsp Vanilla",
    "4 cups Corn flakes",
    "12 oz Chocolate chips",
    "1/2 Another bag of chocolate chips",
    "1 1/2 cups Quaker oats",
    "1 cup Coconut, chopped",
    "1 cup Walnuts or pecans, chopped",
    "12 oz Butterscotch chips",
    "1/2 cup Raisins"
  ],
  "recipeInstructions": "1. Mix all ingredients together in a dishpan or other large container.\n2. Refrigerate for 2 hours.\n3. Form the mixture into clumps and place on prepared cookie sheets.\n4. Bake at 350 degrees Fahrenheit for about 10 minutes.",
  "url": null
}
