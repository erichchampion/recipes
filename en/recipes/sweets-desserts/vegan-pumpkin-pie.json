  "recipeIngredient": [
    "10 oz Firm silken tofu",
    "1 (15 oz) can pumpkin",
    "1/2 cup Fruit source or granulated sugar",
    "1/3 cup Oil (e.g., olive oil)",
    "2 Tbsp Molasses",
    "1 tsp Vanilla extract",
    "1 tbsp Ground cinnamon",
    "1 tbsp Nutmeg",
    "1 tbsp Allspice",
    "1/4 tsp Ginger",
    "Unbaked crust of your choice"
  ],
  "recipeInstructions": "1. Blend all ingredients together until smooth.\n2. Pour the mixture into a pie shell and bake for 1 hour at 350°F (or until done).",
