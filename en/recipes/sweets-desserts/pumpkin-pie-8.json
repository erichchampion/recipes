  "recipeIngredient": [
    "2 cups Pumpkin; cook, mash",
    "1 cup Sugar",
    "1/2 Stick Butter",
    "3 Eggs; beaten",
    "1/2 cup Buttermilk",
    "1 tbsp Vanilla",
    "1 tsp Nutmeg",
    "1 tsp Cinnamon",
    "1/2 tsp Fresh Lemon Juice",
    "Homemade deep-dish pie crust"
  ],
  "recipeInstructions": "1. Mix all ingredients well and add to pie crust.\n2. Bake in a preheated oven for one hour at 350°F.\n3. Cool, slice, and serve.\n4. Top with whipped cream, if desired.",
