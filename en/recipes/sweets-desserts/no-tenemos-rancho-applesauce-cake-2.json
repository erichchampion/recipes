  ],
  "recipeIngredient": [
    "2 cups Unbleached Flour",
    "1 cup Sugar",
    "1 tablespoon Corn Starch",
    "1 tablespoon Cocoa",
    "1/2 teaspoon Cinnamon",
    "1/2 teaspoon Nutmeg",
    "1/2 teaspoon Cloves",
    "2 tablespoons Baking Soda",
    "1/2 teaspoon Salt",
    "1 cup Nuts",
    "1 cup Raisins",
    "1/2 cup Oil",
    "1 teaspoon Vanilla",
    "3 cups HOT Applesauce"
  ],
  "recipeInstructions": "1. Sift together all the dry ingredients, add nuts and raisins.\n2. Stir in the oil, vanilla, and hot applesauce.\n3. Pour into a 9 x 13-inch pan.\n4. Bake at 350 degrees F for 30 to 40 minutes or until done.",
