  "recipeIngredient": [
    "1 cup sugar",
    "1/4 cup shortening",
    "12 oz chocolate syrup",
    "4 eggs",
    "1 teaspoon vanilla",
    "1 cup flour, plus 1 tablespoon",
    "1/2 teaspoon baking powder",
    "1/2 cup nuts, optional"
