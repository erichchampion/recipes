  "recipeIngredient": [
    "1/2 cup Cocoa",
    "1/2 cup Hot water",
    "1 1/2 cups Sugar",
    "Eggs",
    "1/2 cup Sour milk",
    "1 tsp Vanilla",
    "1/2 cup Shortening",
    "1/2 tsp Salt",
    "1 tsp Baking soda",
    "1 tsp Baking powder",
    "2 3/4 cups Flour",
    "Filling:",
    "3/4 cup Confectioner's sugar",
    "3/4 cup Crisco",
    "6 tbsp Marshmallow fluff",
    "1 tsp Vanilla"
  ],
  "recipeInstructions": "1. Mix together all \"cake\" ingredients and drop by teaspoon on cookie sheet.\n2. Bake for 15 minutes at 350°F.\n3. Cream together the \"filling\" ingredients.\n4. Spread between 2 of the \"cakes\".\n5. These will freeze well.",
