  "recipeIngredient": [
    "3 Eggs; slightly beaten",
    "1/2 cup Sugar",
    "1 can Sweetened Condensed Milk",
    "2 Cups Light Cream",
    "20 Ounces Strawberry Soda (Big Red)",
    "1 Teaspoon Vanilla",
    "2 Packages Frozen Strawberries; thawed"
  ],
  "recipeInstructions": "1. Beat the eggs.\n2. Add all other ingredients, including strawberries, to the beaten eggs.\n3. Pour into an ice cream freezer and freeze as usual.",
