  "recipeIngredient": [
    "2 cups Pumpkin (no pie filling)",
    "1 cup Sugar",
    "3 Large Eggs; Beaten",
    "1/4 Cup Butter; Melted",
    "1/2 Cup Buttermilk",
    "1 Teaspoon Cinnamon",
    "1 Teaspoon Nutmeg",
    "1 Teaspoon Ground Ginger",
    "1 Tablespoon Lemon Juice",
    "1 Teaspoon Vanilla",
    "1 Deep Dish Pie Shell (Unbaked)"
  ],
  "recipeInstructions": "1. Mix all ingredients together.\n2. Pour the mixture into the pie shell.\n3. Bake at 350°F for 1 hour.",
