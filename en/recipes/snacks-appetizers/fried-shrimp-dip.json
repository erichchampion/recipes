  "recipeIngredient": [
    "1 cup sugar",
    "2 cups water",
    "1/2 cup sweet peppers, diced",
    "Salt to taste",
    "1 tablespoon vinegar",
    "1 cup pineapple juice",
    "1 tablespoon cornstarch",
    "1 teaspoon paprika"
  ],
  "recipeInstructions": "1. Combine all ingredients in a blender.\n2. Blend until smooth and season with salt to taste.\n3. Serve the dip with fried shrimp.",
