  "recipeIngredient": [
    "3 cups Cottage Cheese",
    "3 packages Cream Cheese (8 oz each)",
    "Softened",
    "6 ounces Blue Cheese",
    "2 teaspoons Worcestershire Sauce",
    "1 teaspoon Seasoned Salt",
    "1/4 teaspoon Red Pepper Sauce",
    "3/4 cup Fresh Parsley, snipped"
  ],
  "recipeInstructions": "1. Combine all ingredients in a large bowl.\n2. Mix until thoroughly blended.\n3. Chill several hours before serving.\n4. Serve with fresh vegetables and crackers.",
