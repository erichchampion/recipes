  "recipeIngredient": [
    "8 oz Cream cheese, softened",
    "1 cup Mayonnaise",
    "2 Cucumbers, seeded, chopped",
    "2 tablespoons Sliced green onion",
    "1 tablespoon Lemon juice",
    "2 teaspoons Snipped fresh dill",
    "1/2 teaspoon Hot pepper sauce"
  ],
  "recipeInstructions": "1. Beat the cream cheese until smooth.\n2. Stir in the remaining ingredients until well mixed.\n3. Cover and chill. Makes 2 1/2 cups.",
