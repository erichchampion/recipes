  "recipeIngredient": [
    "1 lb Crabmeat",
    "2 tablespoons Prepared Mustard",
    "1/2 cup Mayonnaise or Salad Dressing",
    "2 teaspoons Powdered Sugar",
    "2/3 cup White Wine",
    "2 tablespoons Onion, grated",
    "Garlic Salt to Taste"
  ],
  "recipeInstructions": "1. Combine all ingredients except crabmeat in a bowl.\n2. Heat slowly until warmed through.\n3. Gradually add the crabmeat and stir gently.\n4. Serve warm with crackers.",
