  "name": "Vegetable Dip",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Snacks & Appetizers",
  "keywords": [
    "dips",
    "snacks"
  ],
  "recipeIngredient": [
    "16 ounces cream cheese, softened",
    "16 ounces Hellman's mayonnaise",
    "1 tablespoon parsley flakes",
    "1 tablespoon dried minced onion",
    "1 teaspoon seasoned salt",
    "1 teaspoon dill seed",
    "1/4 teaspoon Worcestershire sauce",
    "8 drops Tabasco sauce"
  ],
  "recipeInstructions": "1. Combine all ingredients in a bowl.\n2. Mix thoroughly until well combined.\n3. Cover the mixture and refrigerate until ready to serve.\nServe with raw vegetables.",
  "url": null
}
