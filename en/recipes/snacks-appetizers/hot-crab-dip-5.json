    "3 lb Cream cheese",
    "2 Shallots (chopped)",
    "1/2 bn Scallions (chopped)",
    "1/4 cup Chopped jalapeno peppers",
    "1/2 cup Salsa",
    "1 cup Diced tomatoes",
    "1/2 cup Nacho cheese",
    "1/4 cup Horseradish",
    "2 tbsp Garlic",
    "1/4 cup Lemon juice",
    "1/4 cup Dry sherry",
    "2 tbsp Old Bay seasoning",
    "2 lb Crab claw meat"
