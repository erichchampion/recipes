  "recipeIngredient": [
    "2 cups Cheddar cheese, grated",
    "1 1/2 cups Kraft mayo",
    "1 tablespoon onion and juice, grated",
    "1 tablespoon mustard",
    "1 tablespoon Worcestershire sauce",
    "1 tablespoon Accent seasoning",
    "1 tablespoon parsley, chopped",
    "2 egg whites, beaten"
  ],
  "recipeInstructions": "1. Mix all ingredients thoroughly.\n2. Place the serving dish in a warm pan of water set over medium heat.\n3. Bake for 45 minutes at 350°F (175°C).\n4. Serve with tortilla chips.\n5. Serve warm.",
