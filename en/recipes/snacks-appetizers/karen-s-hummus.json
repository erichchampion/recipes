  "recipeIngredient": [
    "15 oz can garbanzo beans, drained",
    "1/4 cup olive oil",
    "2 tablespoons lemon juice",
    "2 tablespoons fresh parsley",
    "3 cloves garlic, chopped",
    "3 tablespoons chopped onion",
    "1 teaspoon cumin",
    "1/4 teaspoon red pepper flakes",
    "1 tablespoon reduced sodium soy sauce"
  ],
  "recipeInstructions": "1. Place all ingredients in a food processor.\n2. Process until smooth and creamy.\n3. Serve the hummus on pita bread or crackers.\n4. Enjoy it as a dip for raw vegetables.",
