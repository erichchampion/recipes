  "recipeIngredient": [
    "1 teaspoon Salt",
    "4 tablespoons Sugar",
    "4 tablespoons Vinegar",
    "4 tablespoons Butter",
    "4 tablespoons Milk",
    "4 Eggs, beaten",
    "3 8 oz. packages Philadelphia Cream Cheese",
    "3 Jars of Red Pimento (drained)",
    "2 cups Nuts"
  ],
  "recipeInstructions": "1. Cook the salt, sugar, vinegar, butter, and milk together until thickened.\n2. Add the cream cheese to the hot mixture.\n3. Stir in the red pimento and nuts.",
