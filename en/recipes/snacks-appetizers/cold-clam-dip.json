  "recipeIngredient": [
    "10 ounces Clams",
    "6 ounces Philadelphia Cream Cheese",
    "1 tablespoon Lemon Juice",
    "1/2 teaspoon Salt",
    "1/8 teaspoon Pepper",
    "1 tablespoon Worcestershire sauce",
    "1 garlic clove (pressed)",
    "1 tablespoon Tabasco sauce"
  ],
  "recipeInstructions": "1. Blend all ingredients together.\n2. Let set for 2 hours before serving.\n3. Potato chips and all party crackers are good with this dip.",
