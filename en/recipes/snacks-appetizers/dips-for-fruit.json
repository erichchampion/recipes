  "recipeIngredient": [
    "Pina Colada Dip:",
    "1/2 Cup nonfat plain yogurt",
    "1/3 Cup crushed pineapple, drained",
    "2 tbsp flaked coconut",
    "1 tsp sugar",
    "Apricot Cream Dip:",
    "1/2 cup nonfat yogurt or sour cream",
    "1/3 cup all fruit apricot jam",
    "1/8 tsp almond extract",
    "Honey Almond Dip:",
    "2/3 cup nonfat plain yogurt",
    "3 tbsp slivered, toasted almonds (finely chopped)",
    "2 1/2 tbsp honey",
    "Strawberry Cream Dip:",
    "1/2 cup sour cream or nonfat yogurt",
    "1/4 cup all fruit strawberry jam"
  ],
  "recipeInstructions": "1. Combine the ingredients for each dip in a bowl.\n2. Mix well until smooth and creamy.\n3. Serve with fresh fruit.",
