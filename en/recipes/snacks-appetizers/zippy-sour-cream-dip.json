  "recipeIngredient": [
    "2 cups sour cream",
    "1/4 cup prepared horseradish",
    "2 teaspoons Worcestershire sauce",
    "1 teaspoon celery seed",
    "1/2 teaspoon salt",
    "1/2 teaspoon paprika",
    "1/4 cup chopped pimentos"
  ],
  "recipeInstructions": "1. Combine all ingredients in a bowl.\n2. Stir until well mixed.\n3. Cover and refrigerate for at least 30 minutes before serving.\n4. Serve with rye crackers.",
