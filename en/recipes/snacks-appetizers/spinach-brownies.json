  "recipeIngredient": [
    "1 cup Flour",
    "1 cup Milk",
    "1 t Salt",
    "1/2 cup Melted butter",
    "1 lb Sharp Cheddar cheese, grated",
    "1 package Spinach, cooked, drained",
    "2 Eggs",
    "1/2 cup Chopped onions",
    "1 t Baking powder",
    "1 t Marjoram"
  ],
  "recipeInstructions": "1. In a large bowl, combine all ingredients and mix well.\n2. Pour the mixture into a greased 9\" x 13-inch baking dish.\n3. Bake for 45 minutes at 350°F.",
