  "recipeIngredient": [
    "1 lb Prawns, shelled and deveined",
    "3 tbsp Butter",
    "3 tbsp Cream cheese",
    "1 tbsp Sour cream",
    "2 Drops of Tabasco",
    "1/2 tsp Nutmeg",
    "1 Crushed clove of garlic",
    "1 tbsp Lemon juice",
    "1/2 tsp Salt",
    "1/4 tsp Pepper"
  ],
  "recipeInstructions": "1. Mince the prawns and beat together with all other ingredients until smooth.\n2. Garnish with a whole prawn.\n3. Serve with hot toast triangles.",
