  "recipeIngredient": [
    "6 tablespoons Cream cheese, Philadelphia brand",
    "Note: 6 tablespoons equals 6 ounces -",
    "2 teaspoons Cream or Milk",
    "2 teaspoons French Dressing, Miracle Whip",
    "2 tablespoons Ketchup",
    "1 teaspoon Grated onion, finely grated",
    "1 teaspoon Salt"
  ],
  "recipeInstructions": "1. Blend the cream cheese with milk (or cream) until smooth.\n2. Add the remaining ingredients and mix well.\n3. Serve with crackers or potato chips!",
