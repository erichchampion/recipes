  "recipeIngredient": [
    "1/2 cup Mayonnaise",
    "1/2 cup Sour cream",
    "2 teaspoons Grated lime peel",
    "1 tablespoon Lime juice",
    "1 teaspoon Honey",
    "1/2 teaspoon Ground ginger"
