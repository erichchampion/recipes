  "recipeIngredient": [
    "1 can Gorton's clams, drained",
    "2 teaspoons lemon juice",
    "1/8 teaspoon pepper",
    "2 tablespoons minced onion",
    "1 cup soured cream",
    "1/2 teaspoon salt",
    "1/2 teaspoon celery salt"
  ],
  "recipeInstructions": "1. Gently fold the clams into the sour cream.\n2. Add the remaining ingredients and stir gently until blended.\n3. Serve with chips.",
