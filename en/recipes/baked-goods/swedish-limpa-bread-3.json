  "recipeIngredient": [
    "1 cup warm water",
    "2 tablespoons canola oil",
    "1 1/2 tablespoons molasses (unsulphered)",
    "1/2 teaspoon lecithin (liquid or granules)",
    "2 cups whole-wheat flour",
    "1 cup rye flour",
    "3 tablespoons vital wheat gluten",
    "3 tablespoons whey",
    "1 tablespoon carob",
    "1 1/2 teaspoons salt",
    "1 teaspoon anise seed, lightly crushed",
    "1 teaspoon caraway seed",
    "Grated zest of 1 1/2 oranges (preferably organic)",
    "2 teaspoons active dry yeast"
  ],
