  "recipeIngredient": [
    "1 package Active Dry Yeast",
    "3 cups Bread Flour",
    "2 tablespoons Gluten",
    "2 tablespoons Sugar",
    "1 teaspoon Salt",
    "1/8 teaspoon Baking Soda",
    "1/3 cup Instant Nonfat Dry Milk",
    "1/3 cup Walnuts, chopped",
    "1 Egg",
    "2 tablespoons Vegetable Oil",
    "1 teaspoon Vanilla",
    "1 medium Banana, sliced",
    "8 Frozen Strawberries, thawed",
    "1/3 cup Pineapple, crushed",
    "1/3 cup Pineapple Juice, heated",
    "1/2 cup Chocolate Chips",
    "4 Maraschino Cherries, chopped"
  ],
  "recipeInstructions": "1. Place all ingredients except chocolate chips and cherries in the pan in the order listed.\n2. Select the white bread setting and press \"Start\".\n3. Add the chocolate chips and cherries at the beep, just before the end of the kneading cycle.",
