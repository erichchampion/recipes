    "1 cup Old-fashioned rolled oats",
    "1 egg",
    "1/4 cup Sour cream (for Welbilt/Dak-machines add 2 tbsp water)",
    "2 cups Sliced ripe bananas",
    "2 cups Bread flour",
    "1 cup Whole wheat flour",
    "1 tsp Salt",
    "1 tbsp Margarine",
