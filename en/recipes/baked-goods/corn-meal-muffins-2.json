  "recipeIngredient": [
    "3/4 cup Corn meal",
    "1 1/4 cups Flour",
    "1/2 teaspoon Salt",
    "2 teaspoons Baking powder",
    "2 tablespoons Sugar",
    "2 Eggs",
    "3/4 cup Milk",
    "2 tablespoons Lard"
