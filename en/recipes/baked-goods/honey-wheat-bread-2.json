  "recipeIngredient": [
    "1 1/4 cups water, warmed",
    "1 1/2 tablespoons canola oil",
    "1/4 cup honey",
    "1 1/2 teaspoons salt",
    "2 cups whole-wheat flour",
    "3/4 cup unbleached flour",
    "1/4 cup wheat germ",
    "3 tablespoons cracked wheat (optional)",
    "3 1/2 tablespoons vital wheat gluten",
    "1 1/2 tablespoons whey",
    "1 1/4 tablespoons lecithin, granules or liquid",
    "2 tablespoons soy flour (optional)",
    "2 teaspoons active dry yeast"
  ],
  "recipeInstructions": "1. Place all ingredients in the bread machine pan in the order listed. If your machine requires dry ingredients first, reverse the order.\n2. Select the whole wheat cycle and set the crust setting to medium.\n3. Press start to begin the baking process.",
