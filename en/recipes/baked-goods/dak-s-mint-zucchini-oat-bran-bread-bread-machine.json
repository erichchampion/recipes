  "recipeIngredient": [
    "1 package Yeast",
    "1/4 teaspoon Ginger",
    "1 1/4 cup Whole wheat flour",
    "1 1/4 cup Better for Bread white flour",
    "1/2 cup Rolled oats (Quaker Oats)",
    "1/2 cup Oat bran",
    "1 teaspoon Salt",
    "3 tablespoons Gluten",
    "2 tablespoons Olive oil",
    "2 tablespoons Sugar",
    "2 Egg whites, at room temperature",
    "1 cup Water, warmed",
    "1 cup Grated zucchini, warmed",
    "2 tablespoons Mint leaves, chopped"
  ],
  "recipeInstructions": "1. Set the browning control to light.\n2. Place all ingredients in the order listed into the bread machine pan.\n3. Select the \"Oat/French\" setting and press \"Start.\"",
