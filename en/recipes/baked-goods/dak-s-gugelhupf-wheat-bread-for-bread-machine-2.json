  "recipeIngredient": [
    "1 package Yeast",
    "2 cups Whole wheat flour",
    "1/2 cup Nabisco 100% bran cereal (or equivalent)",
    "2 tablespoons Pecans",
    "2 tablespoons Almonds",
    "1 tablespoon Dark brown sugar",
    "1 teaspoon Salt",
    "1 teaspoon Almond extract",
    "1 tablespoon Oil",
    "1 Egg",
    "1 and 3/4 cups Milk"
  ],
  "recipeInstructions": "1. Set the browning control to light.\n2. Place all the ingredients in the bread machine pan, in the order listed.\n- Select \"whole wheat\" setting.\n- Push the start button.",
