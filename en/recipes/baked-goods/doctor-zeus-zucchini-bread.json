  "@type": "Recipe",
  "identifier": "doctor-zeus-zucchini-bread",
  "name": "Doctor Zeus Zucchini Bread",
  "recipeCuisine": "Non-regional",
  "recipeCategory": "Baked Goods",
  "keywords": [
    "baked goods",
    "breads"
  ],
  "recipeIngredient": [
    "3 Eggs",
    "1 cup Oil",
    "2 cups Sugar",
    "2 tbsp Vanilla",
    "2 cups Shredded Zucchini",
    "8 1/2 oz Crushed Pineapple (drained)",
    "1 cup Chopped Nuts",
    "1/2 cup Raisins",
    "3 cups Flour",
    "1 1/2 tsp Cinnamon",
    "1 tsp Salt",
    "3/4 tsp Nutmeg",
    "2 tbsp Baking Soda",
    "1/4 tsp Baking Powder"
  ],
  "recipeInstructions": "1. Beat the eggs, oil, sugar, and vanilla in a large bowl until thick.\n2. Stir in the remaining ingredients. Mix well.\n3. Pour into 2 greased loaf pans.\n4. Bake at 350°F for 1 hour.",
