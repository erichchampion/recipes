  "recipeIngredient": [
    "2 1/4 teaspoons Yeast",
    "3 cups Bread flour",
    "3/4 teaspoon Celery seed",
    "3/4 teaspoon Caraway seed",
    "3/4 teaspoon Ground sage",
    "3/4 teaspoon Ground nutmeg",
    "1 1/2 teaspoons Salt",
    "1 tablespoon Sugar",
    "4 tablespoons Powdered milk",
    "1 tablespoon Butter or margarine",
    "1 cup Water",
    "1 large Egg",
    "1 teaspoon Lemon juice"
  ],
  "recipeInstructions": "1. Combine all ingredients in the bread machine and start the machine.\n2. Do not use a timer.\n3. The Ultimate Bread Machine Cookbook by Lacalamita yields 1 loaf.",
