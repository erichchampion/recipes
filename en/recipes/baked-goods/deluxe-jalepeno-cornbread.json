  "recipeIngredient": [
    "1 cup Yellow cornmeal",
    "17 oz Whole kernel corn",
    "1/2 tsp Baking soda",
    "3/4 tsp Salt",
    "1 Jalepeno peppers, chopped",
    "2 Eggs, beaten",
    "1 cup Buttermilk",
    "Pimento, chopped",
    "1/2 cup Margarine, melted",
    "1 cup Cheddar cheese, grated",
    "1 medium Onion, chopped"
  ],
  "recipeInstructions": "1. Mix all ingredients except cheese.\n2. Pour batter into a well-greased 9x9\" pan.\n3. Sprinkle the 1 C. cheese on top.\n4. Bake at 350°F for 45 minutes.\n5. Serves 4-6 people.",
