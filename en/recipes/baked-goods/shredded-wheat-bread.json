  "recipeIngredient": [
    "1 pound loaf",
    "1 Large shredded-wheat biscuit",
    "7/8 cup Water",
    "2 cups Whole wheat flour",
    "1 teaspoon Salt",
    "1 tablespoon Applesauce",
    "1 1/2 tablespoons Brown sugar",
    "1 1/2 tablespoons Honey",
    "2 teaspoons Yeast"
