  "recipeIngredient": [
    "1 package Yeast",
    "1/4 teaspoon Sugar",
    "1/4 teaspoon Ginger",
    "2 1/4 cups Flour (bread)",
    "1/2 cup Flour (wheat)",
    "2 tablespoons Gluten",
    "1 1/4 cups Instant stuffing mix",
    "1 tablespoon Onion, dried, minced",
    "1 teaspoon Salt",
    "1/2 teaspoon Poultry seasoning",
    "3/4 cup Celery, fresh, diced",
    "1/4 cup Mushrooms, canned, drained",
    "1 Egg",
    "1 tablespoon Vegetable oil",
    "1 cup Chicken broth"
  ],
  "recipeInstructions": "1. Heat chicken broth and water together.\n2. In a large bowl, combine all ingredients except chicken.\n3. Place the mixture on white bread setting.\n4. Press \"Start\".\n5. Add chicken at the \"beep\", just before the end of final kneading.",
