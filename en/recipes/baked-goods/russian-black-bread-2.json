  "recipeIngredient": [
    "1 tablespoon Vinegar",
    "2 tablespoons Vegetable oil",
    "1 cup Water",
    "1 teaspoon Minced dried onion",
    "1 teaspoon Salt",
    "1 teaspoon Sugar",
    "1 teaspoon Instant coffee",
    "1 and 1/2 tablespoons Dark unsweetened cocoa",
    "1 cup Dark rye flour",
    "1 and 1/2 cups Unbleached bread flour",
    "1/2 cup Oat bran",
    "2 teaspoons Caraway seeds (optional)",
    "2 and 1/2 teaspoons Dry active yeast"
  ],
  "recipeInstructions": "1. Place the first eight ingredients in the breadmaker pan. Stir until the coffee and cocoa are dissolved and evenly dispersed.\n2. Add the remaining ingredients.\n3. Set for a regular cycle and press start. Makes a small, short loaf.",
