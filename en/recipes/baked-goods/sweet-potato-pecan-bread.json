  "recipeIngredient": [
    "2 1/4 teaspoons Yeast",
    "3 cups Bread flour",
    "4 tablespoons Rolled oats",
    "1/2 teaspoon Cinnamon",
    "2 pinches Nutmeg",
    "2 tablespoons Salt",
    "2 tablespoons Brown sugar",
    "3 tablespoons Powdered milk",
    "3 tablespoons Butter or margarine",
    "3/4 cup Mashed sweet potatoes, cooked",
    "3/4 cup Water",
    "3 tablespoons Raisins",
    "1/3 cup Chopped Pecans"
  ],
  "recipeInstructions": "1. Combine all ingredients in the bread machine and select the raisin bread cycle.\n2. Add fruit and nuts at the first beep.\n3. Follow the standard settings for the bread machine.",
