  "recipeIngredient": [
    "2 1/4 teaspoons Yeast",
    "3 cups Bread flour",
    "1/2 cup Rolled oats",
    "1 1/2 teaspoons Salt",
    "1 tablespoon Brown sugar, dark",
    "2 tablespoons Powdered milk",
    "1 tablespoon Butter or margarine",
    "1 cup Water, plus 2 tbsp",
    "2 tablespoons Molasses",
    "1 teaspoon Lemon juice"
  ],
