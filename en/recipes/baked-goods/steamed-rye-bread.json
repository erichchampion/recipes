  "recipeIngredient": [
    "1 cup Rye flour",
    "1 tablespoon Salt",
    "1 cup Corn-meal",
    "1 tablespoon Baking soda",
    "3/4 cup Molasses",
    "1/2 cup Raisins",
    "2 cups Water",
    "1 cup Graham flour"
  ],
  "recipeInstructions": "1. Combine the ingredients.\n2. Fill well-oiled 1-pound cans about 2/3 full.\n3. Cover closely and steam for 2 hours.",
