  "recipeIngredient": [
    "LARGE LOAF:",
    "1/4 ounce package active dry yeast",
    "3 1/2 cups bread flour",
    "1/4 teaspoon salt",
    "1 unbeaten egg at room temperature",
    "1/4 cup water",
    "3/4 cup cream style cottage cheese",
    "3/4 cup sour cream",
    "3 tablespoons sugar",
    "3 tablespoons minced dried onion",
    "2 tablespoons dill seed",
    "1 1/2 teaspoons butter or margarine"
  ],
  "recipeInstructions": "In the bread machine, load the yeast, flour, and salt. In a saucepan, combine the rest of the ingredients until warm. Pour this mixture into the bread machine. Process on the white bread cycle with the lightest crust setting.",
