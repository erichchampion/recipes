  "name": "Irish Soda Bread",
  "recipeCuisine": "Europe",
  "recipeCategory": "Baked Goods",
  "keywords": [
    "baked goods",
    "breads"
  ],
  "recipeIngredient": [
    "3 1/2 cups whole wheat flour",
    "1 teaspoon salt",
    "1 teaspoon baking soda",
    "1 teaspoon baking powder",
    "1/2 cup margarine",
    "2 tablespoons caraway seeds",
    "1 1/3 cups buttermilk",
    "1 egg, beaten",
    "raisins"
  ],
  "recipeInstructions": "1. Cream the margarine with dry ingredients and seeds.\n2. Mix in buttermilk, eggs, and raisins.\n3. Knead with extra flour.\n4. Bake at 375°F for about an hour.",
